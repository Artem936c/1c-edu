// Модуль управляемого приложения.

#Область ОбработчикиСобытий

Процедура ПриНачалеРаботыСистемы()

    Если СтрНачинаетсяС(ВРег(ПараметрЗапуска), "SEED_DEMO") Тогда
        ВыполнитьДемоНаполнениеПриЗапуске();
        Возврат;
    КонецЕсли;

    Если СтрНачинаетсяС(ВРег(ПараметрЗапуска), "STATS") Тогда
        Части = СтрРазделить(ПараметрЗапуска, ";");
        ФайлРез = ?(Части.Количество() > 1, СокрЛП(Части[1]), "");
        Сообщить(ОбслуживаниеПользователейВызовСервера.ДемоСтатистикаНаСервере(ФайлРез));
        ЗавершитьРаботуСистемы(Ложь, Истина);
        Возврат;
    КонецЕсли;

    Если СтрНачинаетсяС(ВРег(ПараметрЗапуска), "RLSCHECK") Тогда
        Части = СтрРазделить(ПараметрЗапуска, ";");
        ФайлРез = ?(Части.Количество() > 1, СокрЛП(Части[1]), "");
        Текст = "";
        Попытка
            Текст = ОбслуживаниеПользователейВызовСервера.ПроверкаRLSНаСервере("");
        Исключение
            Текст = "ОШИБКА: " + ОписаниеОшибки();
        КонецПопытки;
        Если Не ПустаяСтрока(ФайлРез) Тогда
            Попытка
                Зап = Новый ЗаписьТекста(ФайлРез, КодировкаТекста.UTF8);
                Зап.ЗаписатьСтроку(Текст);
                Зап.Закрыть();
            Исключение
            КонецПопытки;
        КонецЕсли;
        ЗавершитьРаботуСистемы(Ложь, Истина);
        Возврат;
    КонецЕсли;

    Если СтрНачинаетсяС(ВРег(ПараметрЗапуска), "DASH") Тогда
        Части = СтрРазделить(ПараметрЗапуска, ";");
        ФайлС = ?(Части.Количество() > 1, СокрЛП(Части[1]), "");
        ФайлП = ?(Части.Количество() > 2, СокрЛП(Части[2]), "");
        ФайлСвод = ?(Части.Количество() > 3, СокрЛП(Части[3]), "");
        Свод = ОбслуживаниеПользователейВызовСервера.ДемоДашбордыНаСервере(ФайлС, ФайлП);
        Если Не ПустаяСтрока(ФайлСвод) Тогда
            Зап = Новый ЗаписьТекста(ФайлСвод, КодировкаТекста.UTF8);
            Зап.ЗаписатьСтроку(Свод);
            Зап.Закрыть();
        КонецЕсли;
        Сообщить(Свод);
        ЗавершитьРаботуСистемы(Ложь, Истина);
        Возврат;
    КонецЕсли;

    ОткрытьРабочийСтолТекущегоПользователя();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Открывает рабочий стол в зависимости от вида текущего пользователя.
// Обучающийся — стол обучающегося; преподаватель и администратор — стол преподавателя.
//
&НаКлиенте
Процедура ОткрытьРабочийСтолТекущегоПользователя()

	// При входе сразу открываем дашборд, соответствующий виду пользователя:
	// обучающийся - свой дашборд, преподаватель/администратор - дашборд группы.
	Попытка
		Вид = ОбслуживаниеПользователейВызовСервера.ВидТекущегоПользователя();
		Если Вид = ПредопределенноеЗначение("Перечисление.ВидыПользователей.Обучающийся") Тогда
			ОткрытьФорму("Отчет.ДашбордОбучающегося.Форма.ФормаОтчёта");
		Иначе
			ОткрытьФорму("Отчет.ДашбордПреподавателя.Форма.ФормаОтчёта");
		КонецЕсли;
	Исключение
		// Дашборд не критичен для старта - при ошибке остаемся на главном окне.
	КонецПопытки;

КонецПроцедуры

// Пакетное демонстрационное наполнение: вызывается при старте с параметром
// SEED_DEMO;<каталог fixtures>;<файл результата>. После наполнения завершает работу.
//
&НаКлиенте
Процедура ВыполнитьДемоНаполнениеПриЗапуске()

    Части         = СтрРазделить(ПараметрЗапуска, ";");
    Каталог       = ?(Части.Количество() > 1, СокрЛП(Части[1]), "");
    ФайлРезультата = ?(Части.Количество() > 2, СокрЛП(Части[2]), "");

    Сообщение = ОбслуживаниеПользователейВызовСервера.ВыполнитьДемоНаполнениеНаСервере(
        Каталог, ФайлРезультата);
    Сообщить(Сообщение);

    ЗавершитьРаботуСистемы(Ложь, Истина);

КонецПроцедуры

#КонецОбласти
