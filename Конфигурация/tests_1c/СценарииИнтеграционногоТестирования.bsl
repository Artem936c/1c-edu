// Набор интеграционных сценариев в формате xUnitFor1C.
//
// Модуль предназначен для загрузки как внешняя обработка-тест в среде
// xUnitFor1C / «Тестер»: метод ПолучитьСписокТестов регистрирует сценарии,
// каждый тест выполняет связку общих модулей серверной логики и проверяет
// результат штатными методами контекста (юТест).
//
// Сценарии (раздел 3.6 ВКР, этап 14 плана реализации):
//   1. Прохождение базовой сессии адаптивного тестирования;
//   2. Завершение темы и начисление бейджа;
//   3. Обновление траектории после прохождения темы;
//   4. Пересчёт рейтинга группы;
//   5. Калибровка банка заданий.
//
// Каждый сценарий выполняется в собственной транзакции, которая ОТМЕНЯЕТСЯ
// после проверок — тестовая информационная база не засоряется данными.
// Сценарии самодостаточны: необходимые справочники, регистры и параметры IRT
// создаются помощниками подготовки данных.

Перем юТест;

#Область ПрограммныйИнтерфейсТестов

// Регистрирует сценарии в ядре xUnitFor1C.
//
Функция ПолучитьСписокТестов(КонтекстЯдра) Экспорт

    юТест = КонтекстЯдра;

    ВсеТесты = Новый Массив;
    ВсеТесты.Добавить("Тест_ПрохождениеБазовойСессииАдаптивногоТестирования");
    ВсеТесты.Добавить("Тест_ЗавершениеТемыИНачислениеБейджа");
    ВсеТесты.Добавить("Тест_ОбновлениеТраекторииПослеПрохожденияТемы");
    ВсеТесты.Добавить("Тест_ПересчётРейтингаГруппы");
    ВсеТесты.Добавить("Тест_КалибровкаБанкаЗаданий");

    Возврат ВсеТесты;

КонецФункции

#КонецОбласти

#Область Сценарии

// Сценарий 1. Базовая сессия адаптивного тестирования.
// Проверяет, что сессия открывается, обрабатывает ответы, корректно завершается
// по критерию остановки и фиксирует итоговую оценку в регистре оценок.
//
Процедура Тест_ПрохождениеБазовойСессииАдаптивногоТестирования() Экспорт

    НачатьТранзакцию();
    Попытка
        Данные = ПодготовитьТему("ИТ-Сценарий-1", 12);
        Обучающийся = "Тест Сценарий Иванов";

        Старт = АдаптивноеТестирование.НачатьСессию(Обучающийся, Данные.Тема);
        юТест.ПроверкаЛжи(ЗначениеЗаполнено(Старт.Ошибка), "Старт сессии без ошибок: " + Старт.Ошибка);
        юТест.ПроверкаЗаполненности(Старт.Сессия, "Создан документ ПопыткаТеста");
        юТест.ПроверкаЗаполненности(Старт.ПервоеЗадание, "Выбрано первое задание");

        ТекущееЗадание = Старт.ПервоеЗадание;
        ЗавершитьСессию = Ложь;
        Шагов = 0;
        Пока ТекущееЗадание <> Неопределено И НЕ ЗавершитьСессию И Шагов < 25 Цикл
            Шагов = Шагов + 1;
            // Имитируем способного обучающегося: верно отвечает на лёгкие задания.
            Верно = ИмитироватьОтвет(1.0, ТекущееЗадание, Данные);
            Ответ = АдаптивноеТестирование.ОбработатьОтвет(
                Старт.Сессия, ТекущееЗадание, 0, "", 15, Верно);
            юТест.ПроверкаЛжи(ЗначениеЗаполнено(Ответ.Ошибка),
                "Обработка ответа без ошибок: " + Ответ.Ошибка);
            ТекущееЗадание = Ответ.СледующееЗадание;
            ЗавершитьСессию = Ответ.ЗавершитьСессию;
        КонецЦикла;

        СессияОбъект = Старт.Сессия.ПолучитьОбъект();
        юТест.ПроверкаРавенства("Завершена", СессияОбъект.СтатусСессии, "Сессия завершена");
        юТест.ПроверкаИстины(СессияОбъект.ЧислоЗаданий > 0, "Предъявлено хотя бы одно задание");
        юТест.ПроверкаИстины(СессияОбъект.ЧислоЗаданий <= 20,
            "Число заданий не превышает лимит критерия остановки");

        // Итоговая оценка записана в регистр ОценкиПодготовленностиПоТемам.
        ОценкаЕсть = ЕстьЗаписьОценки(Обучающийся, Данные.Тема);
        юТест.ПроверкаИстины(ОценкаЕсть, "Итоговая оценка θ записана в регистр оценок");

    Исключение
        ОтменитьТранзакцию();
        ВызватьИсключение;
    КонецПопытки;
    ОтменитьТранзакцию();

КонецПроцедуры

// Сценарий 2. Завершение темы и начисление бейджа.
// Проверяет, что за верные ответы начисляются баллы опыта, а проверка условий
// бейджей по результату приводит к появлению документа выдачи бейджа.
//
Процедура Тест_ЗавершениеТемыИНачислениеБейджа() Экспорт

    НачатьТранзакцию();
    Попытка
        Данные = ПодготовитьТему("ИТ-Сценарий-2", 10);
        Бейдж = ПодготовитьБейджЗаПервыйБалл();
        Обучающийся = "Тест Сценарий Петров";

        // Прямое начисление баллов за тему (как при завершении сессии).
        Геймификация.НачислитьБаллы(
            Обучающийся, Данные.Тема,
            Перечисления.ПричиныНачисленияБаллов.ВерныйОтвет, 5, Неопределено);

        БаллыДо = СуммаБалловОпыта(Обучающийся);
        юТест.ПроверкаИстины(БаллыДо >= 5, "Баллы опыта начислены: " + БаллыДо);

        // Проверка накопительных условий бейджей.
        Геймификация.ПроверитьУсловияБейджей(Обучающийся);

        БейджВыдан = ЕстьВыдачаБейджа(Обучающийся, Бейдж);
        юТест.ПроверкаИстины(БейджВыдан, "Бейдж выдан по достижении порога баллов");

    Исключение
        ОтменитьТранзакцию();
        ВызватьИсключение;
    КонецПопытки;
    ОтменитьТранзакцию();

КонецПроцедуры

// Сценарий 3. Обновление траектории после прохождения темы.
// Проверяет, что пересборка траектории формирует запись состояния траектории
// с непустым планом обучения.
//
Процедура Тест_ОбновлениеТраекторииПослеПрохожденияТемы() Экспорт

    НачатьТранзакцию();
    Попытка
        Данные = ПодготовитьТему("ИТ-Сценарий-3", 8);
        Обучающийся = "Тест Сценарий Сидоров";

        // Зафиксируем оценку по теме, чтобы траектория строилась на данных.
        ЗаписатьОценку(Обучающийся, Данные.Тема, 0.8, 0.28);

        ТраекторияОбучения.ПересобратьТраекторию(Обучающийся, Данные.Курс);

        ПланЕсть = ЕстьСостояниеТраектории(Обучающийся, Данные.Курс);
        юТест.ПроверкаИстины(ПланЕсть, "Состояние траектории обучения сформировано");

        Рекомендация = ТраекторияОбучения.РекомендоватьСледующуюТему(Обучающийся, Данные.Курс);
        юТест.ПроверкаИстины(Рекомендация <> Неопределено,
            "Получена рекомендация следующей темы");

    Исключение
        ОтменитьТранзакцию();
        ВызватьИсключение;
    КонецПопытки;
    ОтменитьТранзакцию();

КонецПроцедуры

// Сценарий 4. Пересчёт рейтинга группы.
// Проверяет, что после начисления баллов нескольким обучающимся обновление
// рейтинга упорядочивает их и заполняет регистр рейтинговых позиций.
//
Процедура Тест_ПересчётРейтингаГруппы() Экспорт

    НачатьТранзакцию();
    Попытка
        Данные = ПодготовитьТему("ИТ-Сценарий-4", 6);
        Группа = ПодготовитьУчебнуюГруппу("ИТ-Группа-4",
            "Тест Лидер", "Тест Середняк", "Тест Новичок");

        Геймификация.НачислитьБаллы(Группа.Лидер, Данные.Тема,
            Перечисления.ПричиныНачисленияБаллов.ВерныйОтвет, 30, Неопределено);
        Геймификация.НачислитьБаллы(Группа.Середняк, Данные.Тема,
            Перечисления.ПричиныНачисленияБаллов.ВерныйОтвет, 15, Неопределено);
        Геймификация.НачислитьБаллы(Группа.Новичок, Данные.Тема,
            Перечисления.ПричиныНачисленияБаллов.ВерныйОтвет, 5, Неопределено);

        Геймификация.ОбновитьРейтинг(Группа.Ссылка);

        РангЛидера = РангВРейтинге(Группа.Ссылка, Группа.Лидер);
        РангНовичка = РангВРейтинге(Группа.Ссылка, Группа.Новичок);
        юТест.ПроверкаЗаполненности(РангЛидера, "Рейтинговая позиция лидера записана");
        юТест.ПроверкаИстины(РангЛидера < РангНовичка,
            "Лидер выше новичка в рейтинге (" + РангЛидера + " < " + РангНовичка + ")");

    Исключение
        ОтменитьТранзакцию();
        ВызватьИсключение;
    КонецПопытки;
    ОтменитьТранзакцию();

КонецПроцедуры

// Сценарий 5. Калибровка банка заданий.
// При доступном микросервисе проверяет, что регламентная калибровка обновляет
// параметры IRT (новая версия). Если микросервис недоступен — сценарий
// помечается пропущенным, так как калибровка требует внешних расчётов.
//
Процедура Тест_КалибровкаБанкаЗаданий() Экспорт

    Если НЕ КлиентIRTСервиса.СервисДоступен() Тогда
        юТест.ПометитьПройденным("Микросервис IRT недоступен — калибровка пропущена.");
        Возврат;
    КонецЕсли;

    НачатьТранзакцию();
    Попытка
        Данные = ПодготовитьТему("ИТ-Сценарий-5", 12);
        НаполнитьИсториюОтветов(Данные, 40); // 40 испытуемых × банк темы

        ВерсияДо = МаксВерсияПараметров(Данные.Задания);
        РегламентныеЗаданияОбработчики.КалибровкаБанкаЗаданий();
        ВерсияПосле = МаксВерсияПараметров(Данные.Задания);

        юТест.ПроверкаИстины(ВерсияПосле >= ВерсияДо,
            "Версия параметров не убывает после калибровки");
        // Хотя бы одно задание получило статус «Откалибровано».
        юТест.ПроверкаИстины(ЕстьОткалиброванноеЗадание(Данные.Задания),
            "После калибровки есть откалиброванные задания");

    Исключение
        ОтменитьТранзакцию();
        ВызватьИсключение;
    КонецПопытки;
    ОтменитьТранзакцию();

КонецПроцедуры

#КонецОбласти

#Область ПомощникиПодготовкиДанных

// Создаёт тестовый курс с темой и банком из ЧислоЗаданий заданий
// с заданными параметрами IRT (статус «Откалибровано», версия 1).
//
Функция ПодготовитьТему(Знач Префикс, Знач ЧислоЗаданий)

    Результат = Новый Структура("Курс, Тема, Задания");

    Курс = Справочники.Курсы.СоздатьЭлемент();
    Курс.Наименование = Префикс + " курс";
    Курс.Записать();
    Результат.Курс = Курс.Ссылка;

    Тема = Справочники.Темы.СоздатьЭлемент();
    Тема.Наименование = Префикс + " тема";
    Тема.Владелец = Курс.Ссылка;
    Тема.Записать();
    Результат.Тема = Тема.Ссылка;

    Задания = Новый Массив;
    Для Шаг = 1 По ЧислоЗаданий Цикл
        // Трудность равномерно от -2 до +2 логит.
        B = -2.0 + 4.0 * (Шаг - 1) / Макс(1, ЧислоЗаданий - 1);

        Задание = Справочники.ТестовыеЗадания.СоздатьЭлемент();
        Задание.Наименование = Префикс + " задание " + Шаг;
        Задание.Тема = Тема.Ссылка;
        Задание.ТипЗадания = Перечисления.ТипыТестовыхЗаданий.ОдиночныйВыбор;
        Задание.Формулировка = "Тестовая формулировка " + Шаг;
        Задание.ВидимыйСтатус = Истина;
        Вариант = Задание.ВариантыОтвета.Добавить();
        Вариант.Текст = "Верный";
        Вариант.ЯвляетсяПравильным = Истина;
        Задание.Записать();
        Задания.Добавить(Задание.Ссылка);

        ЗаписатьПараметрыIRT(Задание.Ссылка, 1, B, 1.0,
            Перечисления.СтатусыКалибровкиЗадания.Откалибровано);
    КонецЦикла;
    Результат.Задания = Задания;

    Возврат Результат;

КонецФункции

// Создаёт бейдж с условием «набрать не менее 1 балла опыта».
//
Функция ПодготовитьБейджЗаПервыйБалл()

    Бейдж = Справочники.Бейджи.СоздатьЭлемент();
    Бейдж.Наименование = "ИТ Первый балл";
    Бейдж.Категория = Перечисления.КатегорииБейджей.Стартовый;
    Бейдж.БаллыЗаПолучение = 1;
    Условие = Бейдж.УсловияАктивации.Добавить();
    Условие.ТипУсловия = "СуммаБаллов";
    Условие.ПороговоеЗначение = 1;
    Бейдж.Записать();
    Возврат Бейдж.Ссылка;

КонецФункции

// Создаёт учебную группу с тремя участниками.
//
Функция ПодготовитьУчебнуюГруппу(Знач Имя, Знач Лидер, Знач Середняк, Знач Новичок)

    Группа = Справочники.УчебныеГруппы.СоздатьЭлемент();
    Группа.Наименование = Имя;
    Для Каждого Участник Из Новый Массив(Лидер, Середняк, Новичок) Цикл
        Стр = Группа.Состав.Добавить();
        Стр.Пользователь = Участник;
    КонецЦикла;
    Группа.Записать();

    Результат = Новый Структура("Ссылка, Лидер, Середняк, Новичок",
        Группа.Ссылка, Лидер, Середняк, Новичок);
    Возврат Результат;

КонецФункции

// Записывает строку параметров IRT задания в регистр ПараметрыIRT.
//
Процедура ЗаписатьПараметрыIRT(Знач Задание, Знач Версия, Знач B, Знач A, Знач Статус)

    Набор = РегистрыСведений.ПараметрыIRT.СоздатьНаборЗаписей();
    Набор.Отбор.Задание.Установить(Задание);
    Набор.Отбор.ВерсияПараметров.Установить(Версия);
    Запись = Набор.Добавить();
    Запись.Задание = Задание;
    Запись.ВерсияПараметров = Версия;
    Запись.ТрудностьB = B;
    Запись.ДискриминативностьA = A;
    Запись.СтатусКалибровки = Статус;
    Набор.Записать(Истина);

КонецПроцедуры

// Записывает оценку подготовленности в регистр оценок.
//
Процедура ЗаписатьОценку(Знач Пользователь, Знач Тема, Знач Тета, Знач SE)

    Набор = РегистрыСведений.ОценкиПодготовленностиПоТемам.СоздатьНаборЗаписей();
    Запись = Набор.Добавить();
    Запись.Период = ТекущаяДатаСеанса();
    Запись.Пользователь = Пользователь;
    Запись.Тема = Тема;
    Запись.Тета = Тета;
    Запись.SE = SE;
    Набор.Записать(Ложь);

КонецПроцедуры

// Имитирует ответ обучающегося по 2PL для заданной способности θ.
//
Функция ИмитироватьОтвет(Знач Тета, Знач Задание, Знач Данные)

    B = ТрудностьЗадания(Задание);
    Вероятность = 1.0 / (1.0 + Exp(-(Тета - B)));
    Возврат СлучайноеЧисло01() < Вероятность;

КонецФункции

// Наполняет регистр аналитики/историю ответов синтетическими данными
// (упрощённо: записывает строки ответов в банк темы для калибровки).
//
Процедура НаполнитьИсториюОтветов(Знач Данные, Знач ЧислоИспытуемых)

    Для У = 1 По ЧислоИспытуемых Цикл
        Тета = -2.0 + 4.0 * (У - 1) / Макс(1, ЧислоИспытуемых - 1);
        Старт = АдаптивноеТестирование.НачатьСессию("Калибровка " + У, Данные.Тема);
        Если Старт.Сессия = Неопределено Тогда
            Продолжить;
        КонецЕсли;
        Задание = Старт.ПервоеЗадание;
        Шагов = 0;
        Пока Задание <> Неопределено И Шагов < 12 Цикл
            Шагов = Шагов + 1;
            Верно = ИмитироватьОтвет(Тета, Задание, Данные);
            Ответ = АдаптивноеТестирование.ОбработатьОтвет(
                Старт.Сессия, Задание, 0, "", 10, Верно);
            Если Ответ.ЗавершитьСессию Тогда
                Прервать;
            КонецЕсли;
            Задание = Ответ.СледующееЗадание;
        КонецЦикла;
    КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область ЗапросыПроверок

Функция ТрудностьЗадания(Знач Задание)
    Запрос = Новый Запрос(
        "ВЫБРАТЬ ПЕРВЫЕ 1 ТрудностьB ИЗ РегистрСведений.ПараметрыIRT
        |ГДЕ Задание = &Задание УПОРЯДОЧИТЬ ПО ВерсияПараметров УБЫВ");
    Запрос.УстановитьПараметр("Задание", Задание);
    Выборка = Запрос.Выполнить().Выбрать();
    Возврат ?(Выборка.Следующий(), Выборка.ТрудностьB, 0);
КонецФункции

Функция ЕстьЗаписьОценки(Знач Пользователь, Знач Тема)
    Запрос = Новый Запрос(
        "ВЫБРАТЬ ПЕРВЫЕ 1 Тета ИЗ
