// Формирует HTML-дашборд обучающегося с подставленными JSON-данными.
//
// Параметры:
//  Пользователь  - Строка - ФИО обучающегося.
//  НачалоПериода - Дата   - начало периода аналитики.
//  КонецПериода  - Дата   - конец периода аналитики.
//
// Возвращаемое значение:
//  Строка - HTML-текст дашборда.
//
Функция ПолучитьМакетКакСтроку(Знач Пользователь, Знач НачалоПериода, Знач КонецПериода) Экспорт
    
    Период = Новый Структура("Начало, Окончание", НачалоПериода, КонецПериода);
    JSONДанные = ДанныеДашборда.СформироватьДашбордОбучающегося(Пользователь, Период);
    
    Макет = Отчеты.ДашбордОбучающегося.ПолучитьМакет("HTMLШаблон");
    HTMLТекст = Макет.ПолучитьТекст();
    HTMLТекст = СтрЗаменить(HTMLТекст, "{{DASHBOARD_DATA}}", JSONДанные);
    Возврат HTMLТекст;

КонецФункции

