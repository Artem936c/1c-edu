#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ТекстHTML = Отчеты.ДашбордБиблиотеки.ПолучитьМакетКакСтроку();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

// Обработка кликов внутри дашборда библиотеки. Кликабельные карточки изданий -
// якорные ссылки с data-act="материал" и data-id (UUID материала библиотеки).
&НаКлиенте
Процедура ПолеHTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)

	Якорь = ДанныеСобытия.Anchor;

	Если Якорь = Неопределено Тогда

		Возврат;
	КонецЕсли;

	// Это наш управляющий клик - отменяем штатную навигацию поля HTML.
	СтандартнаяОбработка = Ложь;

	Действие = Якорь.getAttribute("data-act");
	ИД       = Якорь.getAttribute("data-id");

	Если Действие = "материал" И ЗначениеЗаполнено(ИД) Тогда

		ОткрытьМатериал(ИД);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Открывает материал: если у него есть предрендеренные страницы книги - открывает
// встроенный просмотрщик (обработка ПросмотрКниги, страницы PNG в поле HTML);
// иначе показывает карточку справочника.
&НаКлиенте
Процедура ОткрытьМатериал(Знач ИД)

	Если ЕстьКнигаУМатериала(ИД) Тогда
		ОткрытьФорму("Обработка.ПросмотрКниги.Форма.Форма", Новый Структура("МатериалИД", ИД), ЭтотОбъект);
	Иначе
		ПоказатьЗначение(, МатериалПоИД(ИД));
	КонецЕсли;

КонецПроцедуры

// Возвращает Истина, если у материала есть предрендеренные страницы книги.
&НаСервереБезКонтекста
Функция ЕстьКнигаУМатериала(Знач ИД)

	Материал = Справочники.МатериалыБиблиотеки.ПолучитьСсылку(Новый УникальныйИдентификатор(ИД));
	Хранилище = Материал.СтраницыКниги;
	Если Хранилище = Неопределено Тогда
		Возврат Ложь;
	КонецЕсли;

	Страницы = Хранилище.Получить();
	Возврат ТипЗнч(Страницы) = Тип("Массив") И Страницы.Количество() > 0;

КонецФункции

&НаСервереБезКонтекста
Функция МатериалПоИД(Знач ИД)

	Возврат Справочники.МатериалыБиблиотеки.ПолучитьСсылку(Новый УникальныйИдентификатор(ИД));

КонецФункции

#КонецОбласти
