// Формирует HTML-дашборд встроенной библиотеки с подставленными JSON-данными.
//
// Возвращаемое значение:
//  Строка - HTML-текст дашборда библиотеки.
//
Функция ПолучитьМакетКакСтроку() Экспорт

    JSONДанные = ДанныеДашборда.СформироватьДашбордБиблиотеки();

    Макет = Отчеты.ДашбордБиблиотеки.ПолучитьМакет("HTMLШаблон");
    HTMLТекст = Макет.ПолучитьТекст();
    HTMLТекст = СтрЗаменить(HTMLТекст, "{{DASHBOARD_DATA}}", JSONДанные);
    Возврат HTMLТекст;

