// Формирует HTML-дашборд преподавателя для учебной группы.
//
// Параметры:
//  УчебнаяГруппа - СправочникСсылка.УчебныеГруппы - учебная группа.
//  НачалоПериода - Дата - начало периода аналитики.
//  КонецПериода  - Дата - конец периода аналитики.
//
// Возвращаемое значение:
//  Строка - HTML-текст дашборда.
//
Функция ПолучитьМакетКакСтроку(Знач УчебнаяГруппа, Знач НачалоПериода, Знач КонецПериода) Экспорт
    
    Период = Новый Структура("Начало, Окончание", НачалоПериода, КонецПериода);
    JSONДанные = ДанныеДашборда.СформироватьДашбордПреподавателя(УчебнаяГруппа, Период);
    
    Макет = Отчеты.ДашбордПреподавателя.ПолучитьМакет("HTMLШаблон");
    HTMLТекст = Макет.ПолучитьТекст();
    HTMLТекст = СтрЗаменить(HTMLТекст, "{{DASHBOARD_DATA}}", JSONДанные);
    Возврат HTMLТекст;

КонецФункции

