#Область ПрограммныйИнтерфейс

// Формирует HTML-отчёт по сессии тестирования с кривой сходимости θ.
//
// Параметры:
//  СессияСсылка - ДокументСсылка.ПопыткаТеста - сессия адаптивного тестирования.
//
// Возвращаемое значение:
//  Строка - HTML-текст отчёта.
//
Функция ПолучитьМакетКакСтроку(Знач СессияСсылка) Экспорт
    
    Сессия = СессияСсылка.ПолучитьОбъект();
    
    // Собираем данные о сессии в JSON
    Данные = Новый Структура;
    Данные.Вставить("Тема",                Строка(Сессия.Тема));
    Данные.Вставить("Обучающийся",         Строка(Сессия.Обучающийся));
    Данные.Вставить("ДатаНачала",          Сессия.ДатаНачала);
    Данные.Вставить("ДатаОкончания",       Сессия.ДатаОкончания);
    Данные.Вставить("ИтоговаяТета",        Сессия.ИтоговаяОценкаТета);
    Данные.Вставить("ИтоговаяSE",          Сессия.ИтоговаяSE);
    Данные.Вставить("ЧислоЗаданий",        Сессия.ЧислоЗаданий);
    Данные.Вставить("СтатусСессии",        Сессия.СтатусСессии);
    
    // Кривая сходимости θ
    КриваяСходимости = Новый Массив;
    Для Каждого Стр Из Сессия.Ответы Цикл
        Точка = Новый Структура;
        Точка.Вставить("Шаг",   Стр.НомерШага);
        Точка.Вставить("Тета",  Стр.ТекущаяОценкаТета);
        Точка.Вставить("SE",    Стр.ТекущаяSE);
        Точка.Вставить("Верно", Стр.Верно);
        КриваяСходимости.Добавить(Точка);
    КонецЦикла;
    Данные.Вставить("КриваяСходимости", КриваяСходимости);
    
    JSONДанные = ОбщегоНазначенияСерверПриложение.СериализоватьВJSON(Данные);
    
    // Получить макет HTML и подставить данные
    Макет = Отчеты.ОтчётПоПрохождениюТеста.ПолучитьМакет("HTMLШаблон");
    HTMLТекст = Макет.ПолучитьТекст();
    HTMLТекст = СтрЗаменить(HTMLТекст, "{{DASHBOARD_DATA}}", JSONДанные);
    Возврат HTMLТекст;

КонецФункции

