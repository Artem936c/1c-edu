        |   СА.ТипСобытия                       КАК Тип,
        |   КОЛИЧЕСТВО(*)                       КАК Кол
        |ИЗ РегистрСведений.СобытияАналитики КАК СА
        |   ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УчебныеГруппы.Состав КАК Группа
        |       ПО Группа.Пользователь = СА.Пользователь
        |ГДЕ Группа.Ссылка = &Группа И СА.Период МЕЖДУ &Начало И &Окончание
        |СГРУППИРОВАТЬ ПО НАЧАЛОПЕРИОДА(СА.Период, ДЕНЬ), СА.ТипСобытия
        |УПОРЯДОЧИТЬ ПО День, Тип");
    Запрос.УстановитьПараметр("Группа",   УчебнаяГруппа);
    Запрос.УстановитьПараметр("Начало",    Период.Начало);
    Запрос.УстановитьПараметр("Окончание", Период.Окончание);
    
    Точки = Новый Массив;
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Точки.Добавить(Новый Структура("День, Тип, Кол",
            Выборка.День, Строка(Выборка.Тип), Выборка.Кол));
    КонецЦикла;
    Возврат Точки;

КонецФункции

