КонецФункции

// Каталог всех бейджей с условиями получения и отметкой о выдаче пользователю
// (для страницы "Все бейджи"). Возвращает массив структур: Название, Категория,
// Описание, НаградаXP, Получен (Булево), ДатаПолучения, Условия (массив {Тип, Порог}).
Функция СформироватьВсеБейджи(Знач Пользователь)

    // Уже выданные бейджи пользователя -> дата первой выдачи.
    ЗапросВыдан = Новый Запрос(
        "ВЫБРАТЬ
        |   ВыдачаБейджа.Бейдж            КАК Бейдж,
        |   МИНИМУМ(ВыдачаБейджа.ДатаВыдачи) КАК ДатаВыдачи
        |ИЗ Документ.ВыдачаБейджа КАК ВыдачаБейджа
        |ГДЕ ВыдачаБейджа.Обучающийся = &Пользователь И НЕ ВыдачаБейджа.ПометкаУдаления
        |СГРУППИРОВАТЬ ПО ВыдачаБейджа.Бейдж");
    ЗапросВыдан.УстановитьПараметр("Пользователь", Пользователь);
    ВыборкаВыдан = ЗапросВыдан.Выполнить().Выбрать();
    ДатаВыдачиПоБейджу = Новый Соответствие;
    Пока ВыборкаВыдан.Следующий() Цикл
        ДатаВыдачиПоБейджу.Вставить(ВыборкаВыдан.Бейдж, ВыборкаВыдан.ДатаВыдачи);
    КонецЦикла;

    // Все бейджи + их условия активации одним запросом (упорядочены по категории/имени).
    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   Бейджи.Ссылка             КАК Бейдж,
        |   Бейджи.Наименование       КАК Наименование,
        |   Бейджи.Категория          КАК Категория,
        |   Бейджи.Описание           КАК Описание,
        |   Бейджи.БаллыЗаПолучение   КАК НаградаXP,
        |   Условия.ТипУсловия        КАК ТипУсловия,
        |   Условия.ПороговоеЗначение КАК Порог,
        |   Условия.НомерСтроки       КАК НомерСтроки
        |ИЗ Справочник.Бейджи КАК Бейджи
        |   ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Бейджи.УсловияАктивации КАК Условия
        |       ПО Условия.Ссылка = Бейджи.Ссылка
        |ГДЕ НЕ Бейджи.ПометкаУдаления
        |УПОРЯДОЧИТЬ ПО Бейджи.Категория, Бейджи.Наименование, Условия.НомерСтроки");
    Выборка = Запрос.Выполнить().Выбрать();

    Бейджи   = Новый Массив;
    ПоСсылке = Новый Соответствие; // Бейдж -> Структура
    Пока Выборка.Следующий() Цикл
        Запись = ПоСсылке.Получить(Выборка.Бейдж);
        Если Запись = Неопределено Тогда
            Дата = ДатаВыдачиПоБейджу.Получить(Выборка.Бейдж);
            Запись = Новый Структура;
            Запись.Вставить("Название",      Строка(Выборка.Наименование));
            Запись.Вставить("Категория",     Строка(Выборка.Категория));
            Запись.Вставить("Описание",      Выборка.Описание);
            Запись.Вставить("НаградаXP",     Выборка.НаградаXP);
            Запись.Вставить("Получен",       Дата <> Неопределено);
            Запись.Вставить("ДатаПолучения", ?(Дата = Неопределено, "", Дата));
            Запись.Вставить("Условия",       Новый Массив);
            Бейджи.Добавить(Запись);
            ПоСсылке.Вставить(Выборка.Бейдж, Запись);
        КонецЕсли;
        Если ЗначениеЗаполнено(Выборка.ТипУсловия) Тогда
            Запись.Условия.Добавить(Новый Структура("Тип, Порог",
                Строка(Выборка.ТипУсловия), Выборка.Порог));
        КонецЕсли;
    КонецЦикла;
    Возврат Бейджи;

КонецФункции

// Список материалов библиотеки по темам курса (для блока "Материалы" дашборда).
// Возвращает массив структур: Название, Автор, Вид, Тема, МатериалИД, ТемаИД, Приоритет.
Функция СформироватьМатериалыБиблиотеки(Знач Курс)

    Если Не ЗначениеЗаполнено(Курс) Тогда
        Возврат Новый Массив;
    КонецЕсли;

    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   Привязки.Ссылка               КАК Материал,
        |   Привязки.Ссылка.Наименование  КАК Наименование,
        |   Привязки.Ссылка.Автор         КАК Автор,
        |   Привязки.Ссылка.ВидМатериала  КАК Вид,
        |   Привязки.Тема                 КАК Тема,
        |   Привязки.Приоритет            КАК Приоритет
        |ИЗ Справочник.МатериалыБиблиотеки.ПривязкиКТемам КАК Привязки
        |ГДЕ Привязки.Тема.Владелец = &Курс И НЕ Привязки.Ссылка.ПометкаУдаления
        |УПОРЯДОЧИТЬ ПО Привязки.Тема.ПорядокИзучения, Приоритет");
    Запрос.УстановитьПараметр("Курс", Курс);

    Материалы = Новый Массив;
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Материал = Новый Структура;
        Материал.Вставить("Название",   Строка(Выборка.Наименование));
        Материал.Вставить("Автор",      ?(Выборка.Автор = Null, "", Выборка.Автор));
        Материал.Вставить("Вид",        Строка(Выборка.Вид));
        Материал.Вставить("Тема",       Строка(Выборка.Тема));
        Материал.Вставить("МатериалИД", Строка(Выборка.Материал.УникальныйИдентификатор()));
        Материал.Вставить("ТемаИД",     Строка(Выборка.Тема.УникальныйИдентификатор()));
        Материал.Вставить("Приоритет",  Выборка.Приоритет);
        Материалы.Добавить(Материал);
    КонецЦикла;
    Возврат Материалы;

КонецФункции

Функция СформироватьПрогрессПоТемам(Знач Пользователь)
    
    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   Темы.Ссылка                       КАК Тема,
        |   ЕСТЬNULL(СрезПоследних.Тета, -99) КАК Тета
        |ИЗ
        |   Справочник.Темы КАК Темы
        |   ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОценкиПодготовленностиПоТемам.СрезПоследних(, Пользователь = &Пользователь) КАК СрезПоследних
        |       ПО СрезПоследних.Тема = Темы.Ссылка
        |УПОРЯДОЧИТЬ ПО Темы.ПорядокИзучения");
    Запрос.УстановитьПараметр("Пользователь", Пользователь);
    
    Темы = Новый Массив;
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Темы.Добавить(Новый Структура("Тема, Тета, ТемаИД",
            Строка(Выборка.Тема), Выборка.Тета, Строка(Выборка.Тема.УникальныйИдентификатор())));
    КонецЦикла;
    Возврат Темы;
    
КонецФункции

// Все оценки θ пользователя по темам, по датам сдач (для графика "Динамика θ").
// Период намеренно НЕ фильтруется: иначе тема, сданная вне окна дашборда, молча
// пропадала бы с графика, хотя в "Прогрессе" (срез последних) она видна - именно
// из-за этого расхождения часть тем не отображалась. Дата округляется до дня:
// сдачи одного дня встают в одну точку оси X (без дублей подписей), а повторные
// сдачи темы в разные дни дают линию роста.
Функция СформироватьДинамикуТета(Знач Пользователь)

    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   НАЧАЛОПЕРИОДА(Оценки.Период, ДЕНЬ) КАК Дата,
        |   Оценки.Тема   КАК Тема,
        |   Оценки.Тета   КАК Тета,
        |   Оценки.Период КАК Момент
        |ИЗ
        |   РегистрСведений.ОценкиПодготовленностиПоТемам КАК Оценки
        |ГДЕ
        |   Оценки.Пользователь = &Пользователь
        |УПОРЯДОЧИТЬ ПО Момент");
    Запрос.УстановитьПараметр("Пользователь", Пользователь);

    Точки = Новый Массив;
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Точки.Добавить(Новый Структура("Дата, Тема, Тета",
            Выборка.Дата, Строка(Выборка.Тема), Выборка.Тета));
    КонецЦикла;
    Возврат Точки;

КонецФункции

Функция СформироватьРаспределениеТета(Знач УчебнаяГруппа)
    
    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   СП.Тема          КАК Тема,
        |   СП.Тета          КАК Тета
        |ИЗ
        |   Справочник.УчебныеГруппы.Состав КАК Группа
        |   ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОценкиПодготовленностиПоТемам.СрезПоследних КАК СП
        |       ПО СП.Пользователь = Группа.Пользователь
        |ГДЕ Группа.Ссылка = &Группа");
    Запрос.УстановитьПараметр("Группа", УчебнаяГруппа);
    
    Записи = Новый Массив;
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Записи.Добавить(Новый Структура("Тема, Тета",
            Строка(Выборка.Тема), Выборка.Тета));
    КонецЦикла;
    Возврат Записи;
    
КонецФункции

Функция СформироватьТепловуюКартуТем(Знач УчебнаяГруппа)
    
    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   Группа.Пользователь  КАК Пользователь,
        |   СП.Тема              КАК Тема,
        |   СП.Тета              КАК Тета
        |ИЗ
        |   Справочник.УчебныеГруппы.Состав КАК Группа
        |   ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОценкиПодготовленностиПоТемам.СрезПоследних КАК СП
        |       ПО СП.Пользователь = Группа.Пользователь
        |ГДЕ Группа.Ссылка = &Группа");
    Запрос.УстановитьПараметр("Группа", УчебнаяГруппа);
    
    Ячейки = Новый Массив;
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        ПредставлениеТемы = "";
        Если Выборка.Тема <> Null Тогда
            ПредставлениеТемы = Строка(Выборка.Тема);
        КонецЕсли;
        ЗначениеТета = 0;
        Если Выборка.Тета <> Null Тогда
            ЗначениеТета = Выборка.Тета;
        КонецЕсли;
        ИДТемы = ?(Выборка.Тема <> Null, Строка(Выборка.Тема.УникальныйИдентификатор()), "");
        Ячейки.Добавить(Новый Структура("Пользователь, Тема, Тета, ПользовательИД, ТемаИД",
            Выборка.Пользователь.Наименование, ПредставлениеТемы, ЗначениеТета,
            Строка(Выборка.Пользователь.УникальныйИдентификатор()), ИДТемы));
    КонецЦикла;
    Возврат Ячейки;
    
КонецФункции

Функция СформироватьРейтингГруппы(Знач УчебнаяГруппа)
    
    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   СрезПоследних.Пользователь КАК Пользователь,
        |   СрезПоследних.СуммаБаллов  КАК СуммаБаллов,
        |   СрезПоследних.Ранг         КАК Ранг,
        |   СрезПоследних.СредняяТета  КАК СредняяТета
        |ИЗ
        |   РегистрСведений.РейтинговыеПозиции.СрезПоследних(, УчебнаяГруппа = &Группа) КАК СрезПоследних
        |УПОРЯДОЧИТЬ ПО Ранг");
    Запрос.УстановитьПараметр("Группа", УчебнаяГруппа);
    
    Позиции = Новый Массив;
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Позиция = Новый Структура;
        Позиция.Вставить("Пользователь",   Выборка.Пользователь.Наименование);
        Позиция.Вставить("ПользовательИД", Строка(Выборка.Пользователь.УникальныйИдентификатор()));
        Позиция.Вставить("СуммаБаллов",  Выборка.СуммаБаллов);
        Позиция.Вставить("Ранг",         Выборка.Ранг);
        Позиция.Вставить("СредняяТета",  Выборка.СредняяТета);
        Позиции.Добавить(Позиция);
    КонецЦикла;
    Возврат Позиции;
    
КонецФункции

Функция СформироватьАктивность(Знач УчебнаяГруппа, Знач Период)
    
    // Группировка событий по дню и типу
    Запрос = Новый Запрос(
        "ВЫБРАТЬ
