#Область ПрограммныйИнтерфейс

// Формирует JSON-данные для дашборда обучающегося:
// баллы, бейджи, прогресс по траектории, рейтинг, динамика θ.
//
// Параметры:
//  Пользователь - Строка    - ФИО обучающегося.
//  Период       - Структура - Начало (Дата), Окончание (Дата) — период аналитики.
//
// Возвращаемое значение:
//  Строка - JSON-представление данных дашборда.
//
Функция СформироватьДашбордОбучающегося(Знач Пользователь, Знач Период) Экспорт

    ПорогТета = ОбщегоНазначенияСерверПриложение.ЗначениеКонстанты("ПорогТетаДляПрохожденияТемы");
    Мета = ПолучитьМетаОбучающегося(Пользователь);

    Дашборд = Новый Структура;
    Дашборд.Вставить("Пользователь", Строка(Пользователь));
    Дашборд.Вставить("Группа",       Мета.Группа);
    Дашборд.Вставить("Курс",         Мета.Курс);
    Дашборд.Вставить("ПорогТета",    ПорогТета);
    Дашборд.Вставить("Период",       Новый Структура("Начало, Окончание", Период.Начало, Период.Окончание));
    Дашборд.Вставить("KPI",          СформироватьKPIОбучающегося(Пользователь, Мета));
    Дашборд.Вставить("Прогресс",     СформироватьПрогрессПоТемам(Пользователь));
    Дашборд.Вставить("Рекомендация", СформироватьРекомендацию(Пользователь, Мета.КурсСсылка));
    // Активность - всегда последние 14 дней (карточка так и подписана),
    // независимо от общего периода аналитики дашборда.
    ТекущийДень = НачалоДня(ОбщегоНазначенияСерверПриложение.ТекущаяДатаПриложения());
    Период14 = Новый Структура("Начало, Окончание", ТекущийДень - 13 * 86400, КонецДня(ТекущийДень));
    Дашборд.Вставить("Активность",   СформироватьИсториюБаллов(Пользователь, Период14));
    Дашборд.Вставить("РейтингГруппы", СформироватьРейтингГруппыДляСтудента(Мета.ГруппаСсылка, Пользователь));
    Дашборд.Вставить("Бейджи",        СформироватьГалереюБейджей(Пользователь));
    Дашборд.Вставить("ДинамикаТета",  СформироватьДинамикуТета(Пользователь));
    Дашборд.Вставить("Материалы",     СформироватьМатериалыБиблиотеки(Мета.КурсСсылка));
    Дашборд.Вставить("ВсеБейджи",      СформироватьВсеБейджи(Пользователь));
    Дашборд.Вставить("МетрикиБейджей", Геймификация.МетрикиОбучающегося(Пользователь));
    Дашборд.Вставить("ПользовательИД", Строка(Пользователь.УникальныйИдентификатор()));
    // Запуск теста допустим только в собственном дашборде. Когда преподаватель
    // открывает дашборд студента, флаг = Ложь - кнопки старта теста скрываются.
    Дашборд.Вставить("МожноНачинатьТест",
        Пользователь = ОбслуживаниеПользователейВызовСервера.ТекущийПользователь());
    Возврат ОбщегоНазначенияСерверПриложение.СериализоватьВJSON(Дашборд);

КонецФункции

// Формирует JSON-данные для дашборда преподавателя по учебной группе:
// распределение θ, тепловая карта, активность, рейтинг.
//
// Параметры:
//  УчебнаяГруппа - СправочникСсылка.УчебныеГруппы - учебная группа.
//  Период        - Структура - Начало (Дата), Окончание (Дата) — период аналитики.
//
// Возвращаемое значение:
//  Строка - JSON-представление данных дашборда.
//
Функция СформироватьДашбордПреподавателя(Знач УчебнаяГруппа, Знач Период) Экспорт

    ПорогТета = ОбщегоНазначенияСерверПриложение.ЗначениеКонстанты("ПорогТетаДляПрохожденияТемы");
    Мета = ПолучитьМетаГруппы(УчебнаяГруппа);

    Дашборд = Новый Структура;
    Дашборд.Вставить("Группа",         Мета.Наименование);
    Дашборд.Вставить("Преподаватель",  Мета.Преподаватель);
    Дашборд.Вставить("ЧислоСтудентов", Мета.ЧислоСтудентов);
    Дашборд.Вставить("ПорогТета",      ПорогТета);
    Дашборд.Вставить("Период", Новый Структура("Начало, Окончание", Период.Начало, Период.Окончание));
    Дашборд.Вставить("РаспределениеТета", СформироватьРаспределениеТета(УчебнаяГруппа));
    Дашборд.Вставить("ТепловаяКарта",     СформироватьТепловуюКартуТем(УчебнаяГруппа));
    Дашборд.Вставить("РейтингГруппы",     СформироватьРейтингГруппы(УчебнаяГруппа));
    Дашборд.Вставить("Активность",        СформироватьАктивность(УчебнаяГруппа, Период));
    Дашборд.Вставить("АктивныеСтуденты",  СформироватьАктивныхСтудентов(УчебнаяГруппа, Период));
    Дашборд.Вставить("KPI",               СформироватьKPIГруппы(УчебнаяГруппа, ПорогТета));
    Дашборд.Вставить("СтудентыРиска",     СформироватьСтудентовРиска(УчебнаяГруппа, ПорогТета));
    Возврат ОбщегоНазначенияСерверПриложение.СериализоватьВJSON(Дашборд);

КонецФункции

// Формирует JSON-данные для дашборда встроенной библиотеки учебных материалов:
// издания, сгруппированные по темам, с библиографическим описанием.
//
// Возвращаемое значение:
//  Строка - JSON-представление данных дашборда библиотеки.
//
Функция СформироватьДашбордБиблиотеки() Экспорт

    Дашборд = Новый Структура;
    Дашборд.Вставить("Заголовок", "Встроенная библиотека учебных материалов по «1С:Предприятие 8.3»");

    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   Привязки.Тема                          КАК Тема,
        |   Привязки.Тема.ПорядокИзучения          КАК Порядок,
        |   Привязки.Ссылка                        КАК Материал,
        |   Привязки.Ссылка.Наименование           КАК Название,
        |   Привязки.Ссылка.Автор                  КАК Автор,
        |   Привязки.Ссылка.ВидМатериала           КАК Вид,
        |   Привязки.Ссылка.ГодИздания             КАК Год,
        |   Привязки.Ссылка.Издательство           КАК Издательство,
        |   Привязки.Ссылка.ISBN                   КАК ISBN,
        |   Привязки.Ссылка.БиблиографическоеОписание КАК Библиография,
        |   Привязки.Ссылка.КраткоеОписание        КАК Описание,
        |   Привязки.Ссылка.КлючевыеСлова          КАК КлючевыеСлова,
        |   Привязки.Приоритет                     КАК Приоритет
        |ИЗ
        |   Справочник.МатериалыБиблиотеки.ПривязкиКТемам КАК Привязки
        |ГДЕ НЕ Привязки.Ссылка.ПометкаУдаления
        |УПОРЯДОЧИТЬ ПО Порядок, Тема, Приоритет, Название");
    Выборка = Запрос.Выполнить().Выбрать();

    Группы       = Новый Массив;
    ТекущаяТема  = Неопределено;
    ТекущаяГруппа = Неопределено;
    Всего = 0;
    Пока Выборка.Следующий() Цикл
        Если Выборка.Тема <> ТекущаяТема Тогда
            ТекущаяГруппа = Новый Структура("Тема, Материалы", Строка(Выборка.Тема), Новый Массив);
            Группы.Добавить(ТекущаяГруппа);
            ТекущаяТема = Выборка.Тема;
        КонецЕсли;
        Материал = Новый Структура;
        Материал.Вставить("Название",      Строка(Выборка.Название));
        Материал.Вставить("Автор",         ?(Выборка.Автор = Null, "", Выборка.Автор));
        Материал.Вставить("Вид",           Строка(Выборка.Вид));
        Материал.Вставить("Год",           ?(Выборка.Год = Null, 0, Выборка.Год));
        Материал.Вставить("Издательство",  ?(Выборка.Издательство = Null, "", Выборка.Издательство));
        Материал.Вставить("ISBN",          ?(Выборка.ISBN = Null, "", Выборка.ISBN));
        Материал.Вставить("Библиография",  ?(Выборка.Библиография = Null, "", Выборка.Библиография));
        Материал.Вставить("Описание",      ?(Выборка.Описание = Null, "", Выборка.Описание));
        Материал.Вставить("КлючевыеСлова", ?(Выборка.КлючевыеСлова = Null, "", Выборка.КлючевыеСлова));
        Материал.Вставить("Тема",          Строка(Выборка.Тема));
        Материал.Вставить("МатериалИД",    Строка(Выборка.Материал.УникальныйИдентификатор()));
        ТекущаяГруппа.Материалы.Добавить(Материал);
        Всего = Всего + 1;
    КонецЦикла;

    Дашборд.Вставить("ВсегоМатериалов", Всего);
    Дашборд.Вставить("Группы",          Группы);
    Возврат ОбщегоНазначенияСерверПриложение.СериализоватьВJSON(Дашборд);

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Метаданные обучающегося: группа (ссылка/имя/размер) и курс (ссылка/имя).
Функция ПолучитьМетаОбучающегося(Знач Пользователь)

    Результат = Новый Структура;
    Результат.Вставить("Группа",       "");
    Результат.Вставить("ГруппаСсылка", Справочники.УчебныеГруппы.ПустаяСсылка());
    Результат.Вставить("ЧислоВГруппе", 0);
    Результат.Вставить("Курс",         "");
    Результат.Вставить("КурсСсылка",   Справочники.Курсы.ПустаяСсылка());

    Запрос = Новый Запрос(
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Состав.Ссылка КАК Группа,
        |   Состав.Ссылка.Наименование КАК ИмяГруппы
        |ИЗ Справочник.УчебныеГруппы.Состав КАК Состав
        |ГДЕ Состав.Пользователь = &Пользователь");
    Запрос.УстановитьПараметр("Пользователь", Пользователь);
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Результат.ГруппаСсылка = Выборка.Группа;
        Результат.Группа       = Выборка.ИмяГруппы;
    КонецЕсли;

    Если ЗначениеЗаполнено(Результат.ГруппаСсылка) Тогда
        ЗапросК = Новый Запрос(
            "ВЫБРАТЬ КОЛИЧЕСТВО(Состав.Пользователь) КАК Кол
            |ИЗ Справочник.УчебныеГруппы.Состав КАК Состав
            |ГДЕ Состав.Ссылка = &Группа");
        ЗапросК.УстановитьПараметр("Группа", Результат.ГруппаСсылка);
        ВыборкаК = ЗапросК.Выполнить().Выбрать();
        Если ВыборкаК.Следующий() Тогда
            Результат.ЧислоВГруппе = ВыборкаК.Кол;
        КонецЕсли;
    КонецЕсли;

    // Курс — владелец тем, по которым у пользователя есть оценки; иначе первый курс.
    ЗапросКурс = Новый Запрос(
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Оценки.Тема.Владелец КАК Курс,
        |   Оценки.Тема.Владелец.Наименование КАК ИмяКурса
        |ИЗ РегистрСведений.ОценкиПодготовленностиПоТемам КАК Оценки
        |ГДЕ Оценки.Пользователь = &Пользователь И Оценки.Тема.Владелец ЕСТЬ НЕ NULL");
    ЗапросКурс.УстановитьПараметр("Пользователь", Пользователь);
    ВыборкаКурс = ЗапросКурс.Выполнить().Выбрать();
    Если ВыборкаКурс.Следующий() Тогда
        Результат.КурсСсылка = ВыборкаКурс.Курс;
        Результат.Курс       = ВыборкаКурс.ИмяКурса;
    Иначе
        ЗапросПК = Новый Запрос(
            "ВЫБРАТЬ ПЕРВЫЕ 1 Курсы.Ссылка КАК Ссылка, Курсы.Наименование КАК Имя
            |ИЗ Справочник.Курсы КАК Курсы ГДЕ НЕ Курсы.ПометкаУдаления");
        ВыборкаПК = ЗапросПК.Выполнить().Выбрать();
        Если ВыборкаПК.Следующий() Тогда
            Результат.КурсСсылка = ВыборкаПК.Ссылка;
            Результат.Курс       = ВыборкаПК.Имя;
        КонецЕсли;
    КонецЕсли;

    Возврат Результат;

КонецФункции

// KPI обучающегося: XP (всего и за неделю), бейджи (получено/всего/новых),
// позиция в рейтинге и её изменение, серия активных дней (streak).
Функция СформироватьKPIОбучающегося(Знач Пользователь, Знач Мета)

    KPI = Новый Структура;
    KPI.Вставить("XPВсего",          0);
    KPI.Вставить("XPЗаНеделю",       0);
    KPI.Вставить("БейджейПолучено",  0);
    KPI.Вставить("БейджейВсего",     0);
    KPI.Вставить("БейджейНовых",     0);
    KPI.Вставить("Позиция",          0);
    KPI.Вставить("ПозицияИзменение", 0);
    KPI.Вставить("РазмерГруппы",     Мета.ЧислоВГруппе);
    KPI.Вставить("StreakТекущий",    0);
    KPI.Вставить("StreakЛучший",     0);

    НеделяНазад = ОбщегоНазначенияСерверПриложение.ТекущаяДатаПриложения() - 7 * 86400;

    Запрос = Новый Запрос(
        "ВЫБРАТЬ ЕСТЬNULL(СУММА(Об.КоличествоОборот), 0) КАК Всего
        |ИЗ РегистрНакопления.БаллыОпыта.Обороты(, , , Пользователь = &Пользователь) КАК Об");
    Запрос.УстановитьПараметр("Пользователь", Пользователь);
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        KPI.XPВсего = Выборка.Всего;
    КонецЕсли;

    Запрос = Новый Запрос(
        "ВЫБРАТЬ ЕСТЬNULL(СУММА(Об.КоличествоОборот), 0) КАК ЗаНеделю
        |ИЗ РегистрНакопления.БаллыОпыта.Обороты(&Начало, , , Пользователь = &Пользователь) КАК Об");
    Запрос.УстановитьПараметр("Пользователь", Пользователь);
    Запрос.УстановитьПараметр("Начало", НеделяНазад);
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        KPI.XPЗаНеделю = Выборка.ЗаНеделю;
    КонецЕсли;

    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   КОЛИЧЕСТВО(ВБ.Ссылка) КАК Кол,
        |   СУММА(ВЫБОР КОГДА ВБ.ДатаВыдачи >= &Начало ТОГДА 1 ИНАЧЕ 0 КОНЕЦ) КАК Новых
        |ИЗ Документ.ВыдачаБейджа КАК ВБ
        |ГДЕ ВБ.Обучающийся = &Пользователь И НЕ ВБ.ПометкаУдаления");
    Запрос.УстановитьПараметр("Пользователь", Пользователь);
    Запрос.УстановитьПараметр("Начало", НеделяНазад);
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        KPI.БейджейПолучено = ?(Выборка.Кол = Null, 0, Выборка.Кол);
        KPI.БейджейНовых    = ?(Выборка.Новых = Null, 0, Выборка.Новых);
    КонецЕсли;

    Запрос = Новый Запрос("ВЫБРАТЬ КОЛИЧЕСТВО(Бейджи.Ссылка) КАК Кол ИЗ Справочник.Бейджи КАК Бейджи ГДЕ НЕ Бейджи.ПометкаУдаления");
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        KPI.БейджейВсего = Выборка.Кол;
    КонецЕсли;

    // Позиция и её изменение — два последних среза рейтинга.
    Запрос = Новый Запрос(
        "ВЫБРАТЬ ПЕРВЫЕ 2 РП.Период КАК Период, РП.Ранг КАК Ранг
        |ИЗ РегистрСведений.РейтинговыеПозиции КАК РП
        |ГДЕ РП.Пользователь = &Пользователь
        |УПОРЯДОЧИТЬ ПО РП.Период УБЫВ");
    Запрос.УстановитьПараметр("Пользователь", Пользователь);
    Выборка = Запрос.Выполнить().Выбрать();
    Ранги = Новый Массив;
    Пока Выборка.Следующий() Цикл
        Ранги.Добавить(Выборка.Ранг);
    КонецЦикла;
    Если Ранги.Количество() >= 1 Тогда
        KPI.Позиция = Ранги[0];
    КонецЕсли;
    Если Ранги.Количество() >= 2 Тогда
        KPI.ПозицияИзменение = Ранги[1] - Ранги[0]; // > 0 — поднялся в рейтинге
    КонецЕсли;

    Streak = ПолучитьStreak(Пользователь);
    KPI.StreakТекущий = Streak.Текущий;
    KPI.StreakЛучший  = Streak.Лучший;

    Возврат KPI;

КонецФункции

// Серия активных дней: текущая (если последний активный день — сегодня/вчера) и лучшая.
Функция ПолучитьStreak(Знач Пользователь)

    Результат = Новый Структура("Текущий, Лучший", 0, 0);

    Запрос = Новый Запрос(
        "ВЫБРАТЬ РАЗЛИЧНЫЕ НАЧАЛОПЕРИОДА(СА.Период, ДЕНЬ) КАК День
        |ИЗ РегистрСведений.СобытияАналитики КАК СА
        |ГДЕ СА.Пользователь = &Пользователь
        |УПОРЯДОЧИТЬ ПО День");
    Запрос.УстановитьПараметр("Пользователь", Пользователь);
    Выборка = Запрос.Выполнить().Выбрать();
    Дни = Новый Массив;
    Пока Выборка.Следующий() Цикл
        Дни.Добавить(НачалоДня(Выборка.День));
    КонецЦикла;
    Если Дни.Количество() = 0 Тогда
        Возврат Результат;
    КонецЕсли;

    Лучший  = 1;
    Текущая = 1;
    Для Индекс = 1 По Дни.Количество() - 1 Цикл
        Разница = (Дни[Индекс] - Дни[Индекс - 1]) / 86400;
        Если Разница = 1 Тогда
            Текущая = Текущая + 1;
        Иначе
            Текущая = 1;
        КонецЕсли;
        Если Текущая > Лучший Тогда
            Лучший = Текущая;
        КонецЕсли;
    КонецЦикла;

    Сегодня      = НачалоДня(ОбщегоНазначенияСерверПриложение.ТекущаяДатаПриложения());
    ПоследнийДень = Дни[Дни.Количество() - 1];
    Если (Сегодня - ПоследнийДень) / 86400 <= 1 Тогда
        Результат.Текущий = Текущая;
    КонецЕсли;
    Результат.Лучший = Лучший;
    Возврат Результат;

КонецФункции

// Рекомендация следующего шага: тема (с её θ) и приоритетный материал по теме.
Функция СформироватьРекомендацию(Знач Пользователь, Знач Курс)

    Рек = Новый Структура("Есть, Тема, Тета, Материал, Автор", Ложь, "", 0, "", "");
    Рек.Вставить("ТемаИД",     "");
    Рек.Вставить("МатериалИД", "");
    Если Не ЗначениеЗаполнено(Курс) Тогда
        Возврат Рек;
    КонецЕсли;

    ТемаСсылка = ТраекторияОбучения.РекомендоватьСледующуюТему(Пользователь, Курс);
    Если Не ЗначениеЗаполнено(ТемаСсылка) Тогда
        Возврат Рек;
    КонецЕсли;
    Рек.Есть   = Истина;
    Рек.Тема   = Строка(ТемаСсылка);
    Рек.ТемаИД = Строка(ТемаСсылка.УникальныйИдентификатор());

    Запрос = Новый Запрос(
        "ВЫБРАТЬ ЕСТЬNULL(СрезПоследних.Тета, 0) КАК Тета
        |ИЗ РегистрСведений.ОценкиПодготовленностиПоТемам.СрезПоследних(, Пользователь = &Пользователь И Тема = &Тема) КАК СрезПоследних");
    Запрос.УстановитьПараметр("Пользователь", Пользователь);
    Запрос.УстановитьПараметр("Тема",         ТемаСсылка);
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Рек.Тета = Окр(Выборка.Тета, 2);
    КонецЕсли;

    ЗапросМ = Новый Запрос(
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |   Привязки.Ссылка              КАК Ссылка,
        |   Привязки.Ссылка.Наименование КАК Имя,
        |   Привязки.Ссылка.Автор        КАК Автор
        |ИЗ Справочник.МатериалыБиблиотеки.ПривязкиКТемам КАК Привязки
        |ГДЕ Привязки.Тема = &Тема И НЕ Привязки.Ссылка.ПометкаУдаления
        |УПОРЯДОЧИТЬ ПО Привязки.Приоритет");
    ЗапросМ.УстановитьПараметр("Тема", ТемаСсылка);
    ВыборкаМ = ЗапросМ.Выполнить().Выбрать();
    Если ВыборкаМ.Следующий() Тогда
        Рек.Материал   = ВыборкаМ.Имя;
        Рек.Автор      = ?(ВыборкаМ.Автор = Null, "", ВыборкаМ.Автор);
        Рек.МатериалИД = Строка(ВыборкаМ.Ссылка.УникальныйИдентификатор());
    КонецЕсли;

    Возврат Рек;

КонецФункции

// Рейтинг группы для дашборда студента: с недельным приростом XP и флагом «свой».
Функция СформироватьРейтингГруппыДляСтудента(Знач Группа, Знач Пользователь)

    Если Не ЗначениеЗаполнено(Группа) Тогда
        Возврат Новый Массив;
    КонецЕсли;

    НеделяНазад = ОбщегоНазначенияСерверПриложение.ТекущаяДатаПриложения() - 7 * 86400;

    ЗапросП = Новый Запрос(
        "ВЫБРАТЬ
        |   Об.Пользователь          КАК Пользователь,
        |   СУММА(Об.КоличествоОборот) КАК Прирост
        |ИЗ РегистрНакопления.БаллыОпыта.Обороты(&Начало, , , ) КАК Об
        |   ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УчебныеГруппы.Состав КАК Состав
        |       ПО Состав.Пользователь = Об.Пользователь
        |ГДЕ Состав.Ссылка = &Группа
        |СГРУППИРОВАТЬ ПО Об.Пользователь");
    ЗапросП.УстановитьПараметр("Группа", Группа);
    ЗапросП.УстановитьПараметр("Начало", НеделяНазад);
    ВыборкаП = ЗапросП.Выполнить().Выбрать();
    ПриростПоПольз = Новый Соответствие;
    Пока ВыборкаП.Следующий() Цикл
        ПриростПоПольз.Вставить(ВыборкаП.Пользователь, ВыборкаП.Прирост);
    КонецЦикла;

    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   СрезПоследних.Пользователь КАК Пользователь,
        |   СрезПоследних.СуммаБаллов  КАК СуммаБаллов,
        |   СрезПоследних.Ранг         КАК Ранг,
        |   СрезПоследних.СредняяТета  КАК СредняяТета
        |ИЗ РегистрСведений.РейтинговыеПозиции.СрезПоследних(, УчебнаяГруппа = &Группа) КАК СрезПоследних
        |УПОРЯДОЧИТЬ ПО Ранг");
    Запрос.УстановитьПараметр("Группа", Группа);
    Выборка = Запрос.Выполнить().Выбрать();
    Позиции = Новый Массив;
    Пока Выборка.Следующий() Цикл
        Прирост = ПриростПоПольз.Получить(Выборка.Пользователь);
        Поз = Новый Структура;
        Поз.Вставить("Пользователь", Строка(Выборка.Пользователь));
        Поз.Вставить("СуммаБаллов",  Выборка.СуммаБаллов);
        Поз.Вставить("Ранг",         Выборка.Ранг);
        Поз.Вставить("СредняяТета",  Выборка.СредняяТета);
        Поз.Вставить("Прирост",      ?(Прирост = Неопределено, 0, Прирост));
        Поз.Вставить("Свой",         Выборка.Пользователь = Пользователь);
        Позиции.Добавить(Поз);
    КонецЦикла;
    Возврат Позиции;

КонецФункции

Функция СформироватьИсториюБаллов(Знач Пользователь, Знач Период)
    
    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   Обороты.Период            КАК Период,
        |   Обороты.КоличествоОборот  КАК Количество
        |ИЗ
        |   РегистрНакопления.БаллыОпыта.Обороты(&НачалоПериода, &КонецПериода, День, Пользователь = &Пользователь) КАК Обороты
        |УПОРЯДОЧИТЬ ПО Период");
    Запрос.УстановитьПараметр("НачалоПериода", Период.Начало);
    Запрос.УстановитьПараметр("КонецПериода",  Период.Окончание);
    Запрос.УстановитьПараметр("Пользователь",  Пользователь);
    
    Точки = Новый Массив;
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Точки.Добавить(Новый Структура("Дата, Значение", Выборка.Период, Выборка.Количество));
    КонецЦикла;
    Возврат Точки;
    
КонецФункции

Функция СформироватьГалереюБейджей(Знач Пользователь)
    
    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   ВыдачаБейджа.Бейдж                     КАК Бейдж,
        |   ВыдачаБейджа.ДатаВыдачи                КАК ДатаВыдачи,
        |   ВыдачаБейджа.Бейдж.Категория           КАК Категория,
        |   ВыдачаБейджа.Бейдж.Описание            КАК Описание
        |ИЗ Документ.ВыдачаБейджа КАК ВыдачаБейджа
        |ГДЕ ВыдачаБейджа.Обучающийся = &Пользователь И НЕ ВыдачаБейджа.ПометкаУдаления
        |УПОРЯДОЧИТЬ ПО ДатаВыдачи УБЫВ");
    Запрос.УстановитьПараметр("Пользователь", Пользователь);
    
    Бейджи = Новый Массив;
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Бейдж = Новый Структура;
        Бейдж.Вставить("Название",  Строка(Выборка.Бейдж));
        Бейдж.Вставить("Категория", Строка(Выборка.Категория));
        Бейдж.Вставить("Описание",  Выборка.Описание);
        Бейдж.Вставить("ДатаВыдачи", Выборка.ДатаВыдачи);
        Бейджи.Добавить(Бейдж);
    КонецЦикла;
