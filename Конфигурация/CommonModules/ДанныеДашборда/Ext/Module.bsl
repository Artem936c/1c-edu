// Ключевые показатели группы: средняя θ, освоено тем (в среднем) из общего числа,
// число завершённых тестов (всего и за неделю), число студентов в зоне риска.
Функция СформироватьKPIГруппы(Знач УчебнаяГруппа, Знач ПорогТета)

    KPI = Новый Структура;
    KPI.Вставить("СредняяТета",           0);
    KPI.Вставить("ОсвоеноТемВСреднем",    0);
    KPI.Вставить("ЧислоТемВсего",         0);
    KPI.Вставить("ЗавершённыхТестов",     0);
    KPI.Вставить("ЗавершённыхЗаНеделю",   0);
    KPI.Вставить("ВЗонеРиска",            0);

    // Средняя θ по группе (по актуальным оценкам).
    Запрос = Новый Запрос(
        "ВЫБРАТЬ ЕСТЬNULL(СРЕДНЕЕ(СП.Тета), 0) КАК Среднее
        |ИЗ
        |   Справочник.УчебныеГруппы.Состав КАК Состав
        |   ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ОценкиПодготовленностиПоТемам.СрезПоследних КАК СП
        |       ПО СП.Пользователь = Состав.Пользователь
        |ГДЕ Состав.Ссылка = &Группа");
    Запрос.УстановитьПараметр("Группа", УчебнаяГруппа);
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        KPI.СредняяТета = Окр(Выборка.Среднее, 2);
    КонецЕсли;

    // Освоено тем (в среднем) — число тем с θ ≥ порога на студента.
    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   Состав.Пользователь КАК Пользователь,
        |   СУММА(ВЫБОР КОГДА СП.Тета >= &Порог ТОГДА 1 ИНАЧЕ 0 КОНЕЦ) КАК Освоено
        |ИЗ
        |   Справочник.УчебныеГруппы.Состав КАК Состав
        |   ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОценкиПодготовленностиПоТемам.СрезПоследних КАК СП
        |       ПО СП.Пользователь = Состав.Пользователь
        |ГДЕ Состав.Ссылка = &Группа
        |СГРУППИРОВАТЬ ПО Состав.Пользователь");
    Запрос.УстановитьПараметр("Группа", УчебнаяГруппа);
    Запрос.УстановитьПараметр("Порог",  ПорогТета);
    Выборка = Запрос.Выполнить().Выбрать();
    СуммаОсвоено = 0;
    ЧислоСтудентов = 0;
    Пока Выборка.Следующий() Цикл
        СуммаОсвоено = СуммаОсвоено + Выборка.Освоено;
        ЧислоСтудентов = ЧислоСтудентов + 1;
    КонецЦикла;
    Если ЧислоСтудентов > 0 Тогда
        KPI.ОсвоеноТемВСреднем = Окр(СуммаОсвоено / ЧислоСтудентов, 1);
    КонецЕсли;

    Запрос = Новый Запрос("ВЫБРАТЬ КОЛИЧЕСТВО(Темы.Ссылка) КАК Кол ИЗ Справочник.Темы КАК Темы ГДЕ НЕ Темы.ПометкаУдаления");
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        KPI.ЧислоТемВсего = Выборка.Кол;
    КонецЕсли;

    // Завершённые тесты — всего и за последнюю неделю.
    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   КОЛИЧЕСТВО(ПТ.Ссылка) КАК Всего,
        |   СУММА(ВЫБОР КОГДА ПТ.ДатаОкончания >= &НеделяНазад ТОГДА 1 ИНАЧЕ 0 КОНЕЦ) КАК ЗаНеделю
        |ИЗ
        |   Документ.ПопыткаТеста КАК ПТ
        |   ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УчебныеГруппы.Состав КАК Состав
        |       ПО Состав.Пользователь = ПТ.Обучающийся
        |ГДЕ Состав.Ссылка = &Группа И ПТ.СтатусСессии = ""Завершена"" И НЕ ПТ.ПометкаУдаления");
    Запрос.УстановитьПараметр("Группа", УчебнаяГруппа);
    Запрос.УстановитьПараметр("НеделяНазад", ОбщегоНазначенияСерверПриложение.ТекущаяДатаПриложения() - 7 * 86400);
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        KPI.ЗавершённыхТестов   = ?(Выборка.Всего = Null, 0, Выборка.Всего);
        KPI.ЗавершённыхЗаНеделю = ?(Выборка.ЗаНеделю = Null, 0, Выборка.ЗаНеделю);
    КонецЕсли;

    KPI.ВЗонеРиска = СформироватьСтудентовРиска(УчебнаяГруппа, ПорогТета).Количество();

    Возврат KPI;

КонецФункции

// Студенты в зоне риска: средняя θ < 0 ИЛИ простой > 7 дней без активности.
// Для каждого: средняя θ, дней простоя, слабые темы (θ < порога).
Функция СформироватьСтудентовРиска(Знач УчебнаяГруппа, Знач ПорогТета)

    // Средняя θ и слабые темы по студентам группы.
    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   Состав.Пользователь КАК Пользователь,
        |   СП.Тема            КАК Тема,
        |   СП.Тета            КАК Тета
        |ИЗ
        |   Справочник.УчебныеГруппы.Состав КАК Состав
        |   ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОценкиПодготовленностиПоТемам.СрезПоследних КАК СП
        |       ПО СП.Пользователь = Состав.Пользователь
        |ГДЕ Состав.Ссылка = &Группа");
    Запрос.УстановитьПараметр("Группа", УчебнаяГруппа);
    Выборка = Запрос.Выполнить().Выбрать();

    ПоПользователю = Новый Соответствие; // Пользователь -> Структура(Сумма, Кол, СлабыеТемы)
    Пока Выборка.Следующий() Цикл
        Данные = ПоПользователю.Получить(Выборка.Пользователь);
        Если Данные = Неопределено Тогда
            Данные = Новый Структура("Сумма, Кол, Слабые", 0, 0, Новый Массив);
            ПоПользователю.Вставить(Выборка.Пользователь, Данные);
        КонецЕсли;
        Если Выборка.Тета <> Null Тогда
            Данные.Сумма = Данные.Сумма + Выборка.Тета;
            Данные.Кол   = Данные.Кол + 1;
            Если Выборка.Тета < ПорогТета И Данные.Слабые.Количество() < 3 Тогда
                Данные.Слабые.Добавить(Строка(Выборка.Тема));
            КонецЕсли;
        КонецЕсли;
    КонецЦикла;

    // Дата последней активности по студентам.
    ЗапросАктивность = Новый Запрос(
        "ВЫБРАТЬ
        |   СА.Пользователь КАК Пользователь,
        |   МАКСИМУМ(СА.Период) КАК Последняя
        |ИЗ
        |   РегистрСведений.СобытияАналитики КАК СА
        |   ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УчебныеГруппы.Состав КАК Состав
        |       ПО Состав.Пользователь = СА.Пользователь
        |ГДЕ Состав.Ссылка = &Группа
        |СГРУППИРОВАТЬ ПО СА.Пользователь");
    ЗапросАктивность.УстановитьПараметр("Группа", УчебнаяГруппа);
    ВыборкаА = ЗапросАктивность.Выполнить().Выбрать();
    ПоследняяАктивность = Новый Соответствие;
    Пока ВыборкаА.Следующий() Цикл
        ПоследняяАктивность.Вставить(ВыборкаА.Пользователь, ВыборкаА.Последняя);
    КонецЦикла;

    Сейчас = ОбщегоНазначенияСерверПриложение.ТекущаяДатаПриложения();
    Студенты = Новый Массив;
    Для Каждого Элемент Из ПоПользователю Цикл
        Данные = Элемент.Значение;
        СредняяТета = ?(Данные.Кол > 0, Данные.Сумма / Данные.Кол, 0);

        Последняя = ПоследняяАктивность.Получить(Элемент.Ключ);
        Если Последняя = Неопределено Тогда
            ДнейПростоя = 999;
        Иначе
            ДнейПростоя = Цел((Сейчас - Последняя) / 86400);
        КонецЕсли;

        Если СредняяТета < 0 ИЛИ ДнейПростоя > 7 Тогда
            Студент = Новый Структура;
            Студент.Вставить("Студент",        Строка(Элемент.Ключ));
            Студент.Вставить("ПользовательИД", Строка(Элемент.Ключ.УникальныйИдентификатор()));
            Студент.Вставить("СредняяТета", Окр(СредняяТета, 2));
            Студент.Вставить("ДнейПростоя", ДнейПростоя);
            Студент.Вставить("СлабыеТемы",  Данные.Слабые);
            Студенты.Добавить(Студент);
        КонецЕсли;
    КонецЦикла;
    Возврат Студенты;

КонецФункции

// Число уникальных активных студентов группы по дням за период.
Функция СформироватьАктивныхСтудентов(Знач УчебнаяГруппа, Знач Период)

    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   НАЧАЛОПЕРИОДА(СА.Период, ДЕНЬ)        КАК День,
        |   КОЛИЧЕСТВО(РАЗЛИЧНЫЕ СА.Пользователь) КАК Количество
        |ИЗ
        |   РегистрСведений.СобытияАналитики КАК СА
        |   ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.УчебныеГруппы.Состав КАК Состав
        |       ПО Состав.Пользователь = СА.Пользователь
        |ГДЕ Состав.Ссылка = &Группа И СА.Период МЕЖДУ &Начало И &Окончание
        |СГРУППИРОВАТЬ ПО НАЧАЛОПЕРИОДА(СА.Период, ДЕНЬ)
        |УПОРЯДОЧИТЬ ПО День");
    Запрос.УстановитьПараметр("Группа",    УчебнаяГруппа);
    Запрос.УстановитьПараметр("Начало",    Период.Начало);
    Запрос.УстановитьПараметр("Окончание", Период.Окончание);

    Точки = Новый Массив;
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Точки.Добавить(Новый Структура("День, Количество", Выборка.День, Выборка.Количество));
    КонецЦикла;
    Возврат Точки;

КонецФункции

