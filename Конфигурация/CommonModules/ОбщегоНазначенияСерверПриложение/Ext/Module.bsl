#Область ПрограммныйИнтерфейс

// Сериализует структуру или соответствие в JSON-строку (UTF-8).
//
// Параметры:
//  Данные - Произвольный - сериализуемые данные (структура, массив, число, строка, дата).
//
// Возвращаемое значение:
//  Строка - JSON-представление.
//
Функция СериализоватьВJSON(Знач Данные) Экспорт
    
    ЗаписьJSON = Новый ЗаписьJSON;
    ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет);
    ЗаписьJSON.УстановитьСтроку(ПараметрыЗаписи);
    ЗаписатьJSON(ЗаписьJSON, Данные, , "ПреобразоватьЗначениеJSON", , ОбщегоНазначенияСерверПриложение);
    Возврат ЗаписьJSON.Закрыть();

КонецФункции

// Преобразует значения, не сериализуемые в JSON напрямую (даты — в строку ISO 8601,
// прочие непримитивные значения — в строковое представление). Вызывается платформой
// из ЗаписатьJSON.
//
// Параметры:
//  Свойство                - Строка       - имя записываемого свойства.
//  Значение                - Произвольный - сериализуемое значение.
//  ДополнительныеПараметры - Произвольный - не используются.
//
// Возвращаемое значение:
//  Произвольный - значение, пригодное для записи в JSON.
//
Функция ПреобразоватьЗначениеJSON(Свойство, Значение, ДополнительныеПараметры) Экспорт

    Если ТипЗнч(Значение) = Тип("Дата") Тогда
        Возврат ?(ЗначениеЗаполнено(Значение), Формат(Значение, "ДФ=yyyy-MM-ddTHH:mm:ss"), "");
    КонецЕсли;

    Возврат Строка(Значение);

КонецФункции

// Десериализует JSON-строку в структуру/массив.
//
// Параметры:
//  Текст - Строка - входной JSON.
//
// Возвращаемое значение:
//  Произвольный - десериализованные данные.
//
Функция ДесериализоватьИзJSON(Знач Текст) Экспорт
    
    ЧтениеJSON = Новый ЧтениеJSON;
    ЧтениеJSON.УстановитьСтроку(Текст);
    Результат = ПрочитатьJSON(ЧтениеJSON, Истина);
    ЧтениеJSON.Закрыть();
    Возврат Результат;
    
КонецФункции

// Возвращает ФИО текущего пользователя.
// На этапе интеграции БСП заменить на ПользователиСлужебный.ТекущийПользователь().
//
// Возвращаемое значение:
//  Строка - представление пользователя.
//
Функция ТекущийПользовательФИО() Экспорт
    
    Возврат Строка(ПользователиИнформационнойБазы.ТекущийПользователь());
    
КонецФункции

// Возвращает значение одного реквизита объекта одним запросом, без загрузки объекта целиком.
// Замена прямого обращения через точку (ссылка.Реквизит). На этапе интеграции БСП заменить
// на ОбщегоНазначения.ЗначениеРеквизитаОбъекта.
//
// Параметры:
//  Ссылка        - ЛюбаяСсылка - ссылка на объект.
//  ИмяРеквизита  - Строка      - имя реквизита.
//
// Возвращаемое значение:
//  Произвольный - значение реквизита или Неопределено, если объект не найден.
//
Функция ЗначениеРеквизитаОбъекта(Знач Ссылка, Знач ИмяРеквизита) Экспорт

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |   Таблица." + ИмяРеквизита + " КАК Значение
    |ИЗ
    |   " + Ссылка.Метаданные().ПолноеИмя() + " КАК Таблица
    |ГДЕ
    |   Таблица.Ссылка = &Ссылка";
    Запрос.УстановитьПараметр("Ссылка", Ссылка);

    РезультатЗапроса = Запрос.Выполнить();
    Выборка = РезультатЗапроса.Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Значение;
    КонецЕсли;
    Возврат Неопределено;

КонецФункции

// Получает значение константы с проверкой заполненности.
//
// Параметры:
//  ИмяКонстанты - Строка - имя константы конфигурации.
//
// Возвращаемое значение:
//  Произвольный - значение константы.
//
Функция ЗначениеКонстанты(Знач ИмяКонстанты) Экспорт
    
    Возврат Константы[ИмяКонстанты].Получить();
    
КонецФункции

// Фиксирует сбой в журнале регистрации с уровнем "Ошибка".
//
// Параметры:
//  Контекст      - Строка       - источник, например "АдаптивноеТестирование.ОбработатьОтвет".
//  ТекстОшибки   - Строка       - детальное описание.
//  МетаОбъект    - Произвольный - связанный объект метаданных или Неопределено.
//
Процедура ЗафиксироватьСбой(Знач Контекст, Знач ТекстОшибки, МетаОбъект = Неопределено) Экспорт
    
    ЗаписьЖурналаРегистрации(
        Контекст,
        УровеньЖурналаРегистрации.Ошибка,
        МетаОбъект,
        ,
        ТекстОшибки);
        
КонецПроцедуры

// Фиксирует информационное сообщение в журнале регистрации.
//
// Параметры:
//  Контекст   - Строка       - источник события, например "РегламентныеЗаданияОбработчикиПолныеПрава.ОбновлениеРейтинга".
//  Сообщение  - Строка       - текст информационного сообщения.
//  МетаОбъект - Произвольный - связанный объект метаданных или Неопределено.
//
Процедура ЗафиксироватьСобытие(Знач Контекст, Знач Сообщение, МетаОбъект = Неопределено) Экспорт
    
    ЗаписьЖурналаРегистрации(
        Контекст,
        УровеньЖурналаРегистрации.Информация,
        МетаОбъект,
        ,
        Сообщение);
        
КонецПроцедуры

// Возвращает текущую дату сеанса (UTC-нейтральная) — обёртка над ТекущаяДатаСеанса()
// для удобного мокирования в модульных тестах.
//
// Возвращаемое значение:
//  Дата - текущая дата сеанса.
//
Функция ТекущаяДатаПриложения() Экспорт

    Возврат ТекущаяДатаСеанса();

КонецФункции

#КонецОбласти
