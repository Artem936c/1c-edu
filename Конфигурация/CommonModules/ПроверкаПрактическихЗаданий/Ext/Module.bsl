#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Выполняет автоматическую проверку решения практического задания: синтаксический
// анализ кода на встроенном языке 1С и сверку с эталонным чек-листом задания.
// Заполняет в документе ВыполнениеПрактическогоЗадания статус проверки, итоговый
// результат и комментарий (текстовый отчет), затем проводит документ.
//
// Объем проверки соответствует разделу 2.5 ВКР (приём решения, синтаксический анализ,
// формирование отчета). Поведенческая проверка в воспроизводимой ИБ - задел развития.
//
// Параметры:
//  ВыполнениеСсылка - ДокументСсылка.ВыполнениеПрактическогоЗадания - проверяемое решение.
//
// Возвращаемое значение:
//  Структура - результат проверки (см. ПроверитьКод), дополненный ключом Отчет (Строка).
//
Функция ПроверитьВыполнение(Знач ВыполнениеСсылка) Экспорт

    Объект   = ВыполнениеСсылка.ПолучитьОбъект();
    Код      = ИзвлечьТекст(Объект.ПрисоединённоеРешение);
    Чеклист  = ЧеклистЗадания(Объект.Задание);
    Результат = ПроверитьКод(Код, Чеклист);
    Отчет     = СформироватьОтчёт(Результат);

    Объект.СтатусПроверки          = ?(Результат.Пройдено, "Пройдено", "Есть замечания");
    Объект.ИтоговыйРезультат       = Результат.Балл;
    Объект.КомментарийПреподавателя = Отчет;
    Если Не ЗначениеЗаполнено(Объект.ДатаОкончания) Тогда
        Объект.ДатаОкончания = ТекущаяДатаСеанса();
    КонецЕсли;
    Объект.Записать(РежимЗаписиДокумента.Проведение);

    АналитикаПрогресса.ЗарегистрироватьСобытие(
        Объект.Обучающийся, Неопределено,
        Перечисления.ТипыСобытийАналитики.ЗавершениеСессии,
        Новый Структура("Балл, Пройдено", Результат.Балл, Результат.Пройдено),
        ВыполнениеСсылка);

    Результат.Вставить("Отчет", Отчет);
    Возврат Результат;

КонецФункции

// Синтаксический и структурный анализ кода на встроенном языке 1С по чек-листу.
//
// Параметры:
//  Код     - Строка    - исходный текст решения.
//  Чеклист - Структура - ОбязательныеПроцедуры (Массив), ОбязательныеКонструкции (Массив),
//            ЗапрещенныеКонструкции (Массив).
//
// Возвращаемое значение:
//  Структура - Пройдено (Булево), Балл (Число 0..100), Замечания (Массив),
//              Проверок (Число), Успешно (Число).
//
Функция ПроверитьКод(Знач Код, Знач Чеклист) Экспорт

    Замечания = Новый Массив;
    Проверок  = 0;
    Успешно   = 0;

    Если ПустаяСтрока(Код) Тогда
        Замечания.Добавить("Решение не содержит кода на встроенном языке 1С.");
    КонецЕсли;

    // 1. Синтаксис: парность операторных скобок встроенного языка.
    Для Каждого Пара Из ПарыКонструкций() Цикл
        Проверок = Проверок + 1;
        Откр = СчетчикСлов(Код, Пара.Открытие);
        Закр = СчетчикСлов(Код, Пара.Закрытие);
        Если Откр = Закр Тогда
            Успешно = Успешно + 1;
        Иначе
            Замечания.Добавить(СтрШаблон(
                "Нарушена парность: ""%1"" встречается %2 раз, ""%3"" - %4 раз",
                Пара.Открытие, Откр, Пара.Закрытие, Закр));
        КонецЕсли;
    КонецЦикла;

    // 2. Обязательные процедуры/функции.
    Для Каждого Имя Из ЗначениеМассив(Чеклист, "ОбязательныеПроцедуры") Цикл
        Проверок = Проверок + 1;
        Если СодержитПроцедуру(Код, Имя) Тогда
            Успешно = Успешно + 1;
        Иначе
            Замечания.Добавить("Не найдена обязательная процедура или функция: " + Имя);
        КонецЕсли;
    КонецЦикла;

    // 3. Обязательные конструкции (подстроки).
    Для Каждого Фрагмент Из ЗначениеМассив(Чеклист, "ОбязательныеКонструкции") Цикл
        Проверок = Проверок + 1;
        Если СтрНайти(ВРег(Код), ВРег(Фрагмент)) > 0 Тогда
            Успешно = Успешно + 1;
        Иначе
            Замечания.Добавить("Не найдена обязательная конструкция: " + Фрагмент);
        КонецЕсли;
    КонецЦикла;

    // 4. Запрещенные конструкции.
    Для Каждого Фрагмент Из ЗначениеМассив(Чеклист, "ЗапрещенныеКонструкции") Цикл
        Проверок = Проверок + 1;
        Если СтрНайти(ВРег(Код), ВРег(Фрагмент)) = 0 Тогда
            Успешно = Успешно + 1;
        Иначе
            Замечания.Добавить("Использована запрещенная конструкция: " + Фрагмент);
        КонецЕсли;
    КонецЦикла;

    Балл = ?(Проверок > 0, Окр(100 * Успешно / Проверок, 0), 0);

    Результат = Новый Структура;
    Результат.Вставить("Пройдено",  Замечания.Количество() = 0);
    Результат.Вставить("Балл",      Балл);
    Результат.Вставить("Замечания", Замечания);
    Результат.Вставить("Проверок",  Проверок);
    Результат.Вставить("Успешно",   Успешно);
    Возврат Результат;

КонецФункции

// Формирует человекочитаемый текстовый отчет о проверке.
//
// Параметры:
//  Результат - Структура - результат ПроверитьКод.
//
// Возвращаемое значение:
//  Строка - текст отчета.
//
Функция СформироватьОтчёт(Знач Результат) Экспорт

    Строки = Новый Массив;
    Строки.Добавить("ОТЧЕТ О ПРОВЕРКЕ ПРАКТИЧЕСКОГО ЗАДАНИЯ");
    Строки.Добавить("Итог: " + ?(Результат.Пройдено, "решение принято", "есть замечания"));
    Строки.Добавить(СтрШаблон("Пройдено проверок: %1 из %2 (%3 из 100 баллов)",
        Результат.Успешно, Результат.Проверок, Результат.Балл));
    Строки.Добавить("");
    Если Результат.Замечания.Количество() > 0 Тогда
        Строки.Добавить("Найденные расхождения:");
        Для Каждого Замечание Из Результат.Замечания Цикл
            Строки.Добавить("  - " + Замечание);
        КонецЦикла;
    Иначе
        Строки.Добавить("Расхождений с эталонным чек-листом не обнаружено.");
    КонецЕсли;
    Возврат СтрСоединить(Строки, Символы.ПС);

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПарыКонструкций()

    Пары = Новый Массив;
    Пары.Добавить(Новый Структура("Открытие, Закрытие", "Процедура", "КонецПроцедуры"));
    Пары.Добавить(Новый Структура("Открытие, Закрытие", "Функция",   "КонецФункции"));
    Пары.Добавить(Новый Структура("Открытие, Закрытие", "Если",      "КонецЕсли"));
    Пары.Добавить(Новый Структура("Открытие, Закрытие", "Цикл",      "КонецЦикла"));
    Пары.Добавить(Новый Структура("Открытие, Закрытие", "Попытка",   "КонецПопытки"));
    Возврат Пары;

КонецФункции

// Считает вхождения слова как отдельного токена (не как подстроки), чтобы, например,
// "Если" не засчитывалось внутри "КонецЕсли" или "ИначеЕсли".
Функция СчетчикСлов(Знач Текст, Знач Слово)

    Если ПустаяСтрока(Текст) Или ПустаяСтрока(Слово) Тогда
        Возврат 0;
    КонецЕсли;
    Норм = " " + ЗаменитьРазделителиНаПробелы(ВРег(Текст)) + " ";
    Возврат СтрЧислоВхождений(Норм, " " + ВРег(Слово) + " ");

КонецФункции

Функция ЗаменитьРазделителиНаПробелы(Знач Текст)

    Разделители = Символы.ПС + Символы.ВК + Символы.Таб + ".,;:()[]{}=<>+-*/&|%!" + """" + "'";
    Результат = Текст;
    Для Поз = 1 По СтрДлина(Разделители) Цикл
        Результат = СтрЗаменить(Результат, Сред(Разделители, Поз, 1), " ");
    КонецЦикла;
    Возврат Результат;

КонецФункции

Функция СодержитПроцедуру(Знач Код, Знач Имя)

    КодВРег = ВРег(Код);
    ИмяВРег = ВРег(СокрЛП(Имя));
    Возврат СтрНайти(КодВРег, "ПРОЦЕДУРА " + ИмяВРег) > 0
        ИЛИ СтрНайти(КодВРег, "ФУНКЦИЯ " + ИмяВРег) > 0;

КонецФункции

Функция ЗначениеМассив(Знач Чеклист, Знач Ключ)

    Значение = Неопределено;
    Если ТипЗнч(Чеклист) = Тип("Структура") И Чеклист.Свойство(Ключ) Тогда
        Значение = Чеклист[Ключ];
    ИначеЕсли ТипЗнч(Чеклист) = Тип("Соответствие") Тогда
        Значение = Чеклист.Получить(Ключ);
    КонецЕсли;
    Если ТипЗнч(Значение) = Тип("Массив") Тогда
        Возврат Значение;
    КонецЕсли;
    Возврат Новый Массив;

КонецФункции

Функция ЧеклистЗадания(Знач Задание)

    Пустой = Новый Структура("ОбязательныеПроцедуры, ОбязательныеКонструкции, ЗапрещенныеКонструкции",
        Новый Массив, Новый Массив, Новый Массив);
    Если Не ЗначениеЗаполнено(Задание) Тогда
        Возврат Пустой;
    КонецЕсли;
    Хранилище = ОбщегоНазначенияСерверПриложение.ЗначениеРеквизитаОбъекта(Задание, "ЭталонныйАртефакт");
    JSON = ИзвлечьТекст(Хранилище);
    Если ПустаяСтрока(JSON) Тогда
        Возврат Пустой;
    КонецЕсли;
    Попытка
        Возврат ОбщегоНазначенияСерверПриложение.ДесериализоватьИзJSON(JSON);
    Исключение
        Возврат Пустой;
    КонецПопытки;

КонецФункции

// Извлекает текст из реквизита типа ХранилищеЗначения (строка кода или двоичные данные).
Функция ИзвлечьТекст(Знач Хранилище)

    Если Хранилище = Неопределено Тогда
        Возврат "";
    КонецЕсли;
    Значение = Хранилище;
    Если ТипЗнч(Хранилище) = Тип("ХранилищеЗначения") Тогда
        Значение = Хранилище.Получить();
    КонецЕсли;
    Если Значение = Неопределено Тогда
        Возврат "";
    КонецЕсли;
    Если ТипЗнч(Значение) = Тип("Строка") Тогда
        Возврат Значение;
    КонецЕсли;
    Если ТипЗнч(Значение) = Тип("ДвоичныеДанные") Тогда
        Возврат ПолучитьСтрокуИзДвоичныхДанных(Значение, "UTF-8");
    КонецЕсли;
    Возврат Строка(Значение);

КонецФункции

#КонецОбласти

#КонецЕсли
