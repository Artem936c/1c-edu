#Область ПрограммныйИнтерфейс

// Регистрирует событие в регистре сведений СобытияАналитики.
//
// Параметры:
//  Пользователь    - Строка       - ФИО обучающегося.
//  Тема            - СправочникСсылка.Темы - тема события (может быть Неопределено).
//  ТипСобытия      - ПеречислениеСсылка.ТипыСобытийАналитики - тип события.
//  ПолезнаяНагрузка - Произвольный - дополнительные данные события (сериализуются в JSON).
//  ИсточникСсылка  - ЛюбаяСсылка   - объект-источник события (может быть Неопределено).
//
Процедура ЗарегистрироватьСобытие(Знач Пользователь, Знач Тема, Знач ТипСобытия,
                                   Знач ПолезнаяНагрузка = Неопределено,
                                   Знач ИсточникСсылка = Неопределено) Экспорт
    
    Попытка
        НаборЗаписей = РегистрыСведений.СобытияАналитики.СоздатьНаборЗаписей();
        Запись = НаборЗаписей.Добавить();
        Запись.Период          = ТекущаяДатаСеанса();
        Запись.Пользователь    = Пользователь;
        Запись.Тема            = Тема;
        Запись.ТипСобытия      = ТипСобытия;
        // Уникальный ключ - иначе несколько событий с одинаковыми
        // период/пользователь/тема/тип в одну секунду дают конфликт ключа.
        Запись.КлючСобытия     = Строка(Новый УникальныйИдентификатор());
        Если ПолезнаяНагрузка = Неопределено Тогда
            Запись.ПолезнаяНагрузка = "{}";
        Иначе
            Запись.ПолезнаяНагрузка = ОбщегоНазначенияСерверПриложение.СериализоватьВJSON(ПолезнаяНагрузка);
        КонецЕсли;
        Запись.ИсточникСсылка  = ИсточникСсылка;
		
		НаборЗаписей.Записать(Ложь);
    Исключение
        ОбщегоНазначенияСерверПриложение.ЗафиксироватьСбой(
            "АналитикаПрогресса.ЗарегистрироватьСобытие", ОписаниеОшибки());
    КонецПопытки;
    
КонецПроцедуры

// Возвращает агрегаты по событиям пользователя за период (для отчётов СКД).
//
// Параметры:
//  Пользователь  - Строка - ФИО обучающегося.
//  ДатаНачала    - Дата   - начало периода.
//  ДатаОкончания - Дата   - конец периода.
//
// Возвращаемое значение:
//  Соответствие - ПеречислениеСсылка.ТипыСобытийАналитики -> Число (количество событий).
//
Функция ПолучитьАгрегатыПоПериоду(Знач Пользователь, Знач ДатаНачала, Знач ДатаОкончания) Экспорт
    
    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   СА.ТипСобытия     КАК Тип,
        |   КОЛИЧЕСТВО(*)     КАК Кол
        |ИЗ РегистрСведений.СобытияАналитики КАК СА
        |ГДЕ СА.Пользователь = &Пользователь И СА.Период МЕЖДУ &Начало И &Окончание
        |СГРУППИРОВАТЬ ПО СА.ТипСобытия");
    Запрос.УстановитьПараметр("Пользователь", Пользователь);
    Запрос.УстановитьПараметр("Начало",       ДатаНачала);
    Запрос.УстановитьПараметр("Окончание",    ДатаОкончания);
    
    Результат = Новый Соответствие;
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Результат.Вставить(Выборка.Тип, Выборка.Кол);
    КонецЦикла;
    Возврат Результат;
    
КонецФункции

#КонецОбласти
