#Область ПрограммныйИнтерфейс

// Расчёт вероятности правильного ответа по модели Раша (1PL).
// P(θ, b) = exp(θ - b) / (1 + exp(θ - b)).
//
// Параметры:
//  Тета       - Число - оценка способности θ.
//  ТрудностьB - Число - параметр трудности задания b.
//
// Возвращаемое значение:
//  Число - вероятность правильного ответа (0..1).
//
Функция ВероятностьРаш(Знач Тета, Знач ТрудностьB) Экспорт

    ЭкспЗначение = Exp(Тета - ТрудностьB);
    Возврат ЭкспЗначение / (1 + ЭкспЗначение);

КонецФункции

// Информация Фишера для модели Раша.
// I(θ, b) = P * (1 - P).
//
// Параметры:
//  Тета       - Число - оценка способности θ.
//  ТрудностьB - Число - параметр трудности задания b.
//
// Возвращаемое значение:
//  Число - значение информации Фишера.
//
Функция ИнформацияФишераРаш(Знач Тета, Знач ТрудностьB) Экспорт

    Вероятность = ВероятностьРаш(Тета, ТрудностьB);
    Возврат Вероятность * (1 - Вероятность);

КонецФункции

// Оценка θ методом Ньютона-Рафсона для модели Раша (без обращения к микросервису).
//
// Параметры:
//  ИсторияОтветов - Массив из Структура - история ответов:
//   * ТрудностьB - Число  - параметр трудности задания.
//   * Верно      - Булево - признак правильного ответа.
//  НачальнаяТета  - Число - начальное приближение θ.
//  МаксИтераций   - Число - максимум итераций метода Ньютона-Рафсона.
//
// Возвращаемое значение:
//  Структура:
//   * Тета    - Число  - оценка способности θ.
//   * SE      - Число  - стандартная ошибка оценки.
//   * Сошлось - Булево - признак сходимости метода.
//
Функция ОценитьТетаЛокально(Знач ИсторияОтветов, Знач НачальнаяТета = 0, Знач МаксИтераций = 25) Экспорт
    
    Результат = Новый Структура("Тета, SE, Сошлось", НачальнаяТета, 0, Ложь);
    Если ИсторияОтветов.Количество() = 0 Тогда
        Результат.SE = 99;
        Возврат Результат;
    КонецЕсли;
    
    МинимальнаяИнформация = 0.0001;  // ниже — итерации Ньютона-Рафсона неустойчивы
    ПорогСходимости       = 0.001;   // |шаг| меньше — считаем, что θ сошлась
    ГраницаТета           = 5;       // θ ограничиваем диапазоном [-5; 5]

    Тета = НачальнаяТета;
    Для Итерация = 1 По МаксИтераций Цикл
        Числитель = 0;       // ∑(ответ - P)
        Знаменатель = 0;     // ∑ P*(1-P)  — информация Фишера
        Для Каждого Ответ Из ИсторияОтветов Цикл
            Вероятность = ВероятностьРаш(Тета, Ответ.ТрудностьB);
            ФактическийОтвет = 0;
            Если Ответ.Верно Тогда
                ФактическийОтвет = 1;
            КонецЕсли;
            Числитель = Числитель + (ФактическийОтвет - Вероятность);
            Знаменатель = Знаменатель + Вероятность * (1 - Вероятность);
        КонецЦикла;

        Если Знаменатель < МинимальнаяИнформация Тогда
            Прервать;
        КонецЕсли;

        Шаг = Числитель / Знаменатель;
        Тета = Тета + Шаг;

        Если Тета > ГраницаТета Тогда
            Тета = ГраницаТета;
        КонецЕсли;
        Если Тета < -ГраницаТета Тогда
            Тета = -ГраницаТета;
        КонецЕсли;

        Если Макс(Шаг, -Шаг) < ПорогСходимости Тогда
            Результат.Сошлось = Истина;
            Прервать;
        КонецЕсли;
    КонецЦикла;
    
    // SE = 1 / sqrt(I(θ))
    ПолнаяИнформация = 0;
    Для Каждого Ответ Из ИсторияОтветов Цикл
        ПолнаяИнформация = ПолнаяИнформация + ИнформацияФишераРаш(Тета, Ответ.ТрудностьB);
    КонецЦикла;
    
    Если ПолнаяИнформация > 0 Тогда
        Результат.SE = 1 / Sqrt(ПолнаяИнформация);
    Иначе
        Результат.SE = 99;
    КонецЕсли;
    Результат.Тета = Тета;
    Возврат Результат;
    
КонецФункции

// Выбор задания с максимальной информацией Фишера среди кандидатов.
//
// Параметры:
//  Кандидаты        - Массив из Структура - кандидаты:
//   * Ссылка     - СправочникСсылка.ТестовыеЗадания - задание.
//   * ТрудностьB - Число - параметр трудности задания.
//  ТекущаяТета      - Число - текущая оценка θ.
//  ИсключитьЗадания - Соответствие - СправочникСсылка.ТестовыеЗадания -> Булево (исключаемые задания).
//
// Возвращаемое значение:
//  СправочникСсылка.ТестовыеЗадания, Неопределено - выбранное задание или Неопределено.
//
Функция ВыбратьЗаданиеЛокально(Знач Кандидаты, Знач ТекущаяТета, Знач ИсключитьЗадания) Экспорт
    
    ЛучшееЗадание = Неопределено;
    МаксИнформация = -1;
    
    Для Каждого Задание Из Кандидаты Цикл
        Если ИсключитьЗадания.Получить(Задание.Ссылка) <> Неопределено Тогда
            Продолжить;
        КонецЕсли;
        Информация = ИнформацияФишераРаш(ТекущаяТета, Задание.ТрудностьB);
        Если Информация > МаксИнформация Тогда
            МаксИнформация = Информация;
            ЛучшееЗадание = Задание.Ссылка;
        КонецЕсли;
    КонецЦикла;
    
    Возврат ЛучшееЗадание;
    
КонецФункции

#КонецОбласти
