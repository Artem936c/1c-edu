#Область ПрограммныйИнтерфейс

// Запрашивает у микросервиса следующее задание по критерию максимальной информации Фишера.
//
// Параметры:
//  Пакет - Структура - входные данные запроса:
//   * ТекущаяТета           - Число - текущая оценка способности.
//   * ИспользованныеЗадания - Массив из УникальныйИдентификатор - GUID уже предъявленных заданий.
//   * Кандидаты             - Массив из Структура - задания-кандидаты (Идентификатор, ТрудностьB, ДискриминативностьA).
//
// Возвращаемое значение:
//  Структура:
//   * Успех      - Булево       - признак успешного ответа сервиса.
//   * КодHTTP    - Число        - код состояния HTTP.
//   * ТелоОтвета - Произвольный - разобранное тело ответа или Неопределено.
//   * Ошибка     - Строка       - текст ошибки (пустая строка при успехе).
//
Функция ВыбратьСледующееЗадание(Знач Пакет) Экспорт
    
    Возврат ВыполнитьЗапрос("/select_next_item", Пакет);
    
КонецФункции

// Запрашивает у микросервиса оценку θ и SE по истории ответов.
//
// Параметры:
//  Пакет - Структура - входные данные запроса:
//   * ИсторияОтветов - Массив из Структура - элементы (Идентификатор, ТрудностьB, Дискриминативность, Верно).
//   * Априор         - Структура - параметры априорного распределения (μ, σ).
//
// Возвращаемое значение:
//  Структура:
//   * Успех      - Булево       - признак успешного ответа сервиса.
//   * КодHTTP    - Число        - код состояния HTTP.
//   * ТелоОтвета - Произвольный - разобранное тело ответа или Неопределено.
//   * Ошибка     - Строка       - текст ошибки (пустая строка при успехе).
//
Функция ОценитьТета(Знач Пакет) Экспорт
    
    Возврат ВыполнитьЗапрос("/estimate_theta", Пакет);
    
КонецФункции

// Запрашивает у микросервиса калибровку банка заданий по теме.
//
// Параметры:
//  Пакет - Структура - входные данные запроса:
//   * Тема    - Строка - идентификатор темы.
//   * Матрица - Массив - тройки (Пользователь, Задание, Ответ:0/1).
//   * Метод   - Строка - "JMLE" или "MMLE".
//
// Возвращаемое значение:
//  Структура:
//   * Успех      - Булево       - признак успешного ответа сервиса.
//   * КодHTTP    - Число        - код состояния HTTP.
//   * ТелоОтвета - Произвольный - разобранное тело ответа (в т.ч. new_params) или Неопределено.
//   * Ошибка     - Строка       - текст ошибки (пустая строка при успехе).
//
Функция КалиброватьБанк(Знач Пакет) Экспорт
    
    Возврат ВыполнитьЗапрос("/calibrate_bank", Пакет);
    
КонецФункции

// Проверяет доступность микросервиса (эндпоинт /health).
//
// Возвращаемое значение:
//  Булево - Истина, если сервис ответил кодом 200.
//
Функция СервисДоступен() Экспорт
    
    Ответ = ВыполнитьЗапрос("/health", Новый Структура);
    Возврат Ответ.Успех;
    
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Выполняет HTTP-POST к указанному эндпоинту микросервиса IRT, возвращает разобранный ответ.
//
Функция ВыполнитьЗапрос(Знач Эндпоинт, Знач ТелоСтруктура)
    
    Результат = Новый Структура;
    Результат.Вставить("Успех",      Ложь);
    Результат.Вставить("КодHTTP",    0);
    Результат.Вставить("ТелоОтвета", Неопределено);
    Результат.Вставить("Ошибка",     "");
    
    URL = ОбщегоНазначенияСерверПриложение.ЗначениеКонстанты("URLМикросервисаIRT");
    Если ПустаяСтрока(URL) Тогда
        Результат.Ошибка = "Не задан URL микросервиса IRT (константа URLМикросервисаIRT).";
        Возврат Результат;
    КонецЕсли;
    
    Таймаут = ОбщегоНазначенияСерверПриложение.ЗначениеКонстанты("ТаймаутЗапросаКМикросервису");
    Если Таймаут = 0 Тогда
        Таймаут = 10;
    КонецЕсли;
    
    Попытка
        URLРазобран = РазобратьURL(URL);
        ЗащищённоеСоединение = Неопределено;
        Если URLРазобран.Защищённое Тогда
            ЗащищённоеСоединение = Новый ЗащищенноеСоединениеOpenSSL;
        КонецЕсли;
        Соединение = Новый HTTPСоединение(
            URLРазобран.Хост,
            URLРазобран.Порт,
            ,
            ,
            ,
            Таймаут,
            ЗащищённоеСоединение);
        
        Запрос = Новый HTTPЗапрос(URLРазобран.Путь + Эндпоинт);
        Запрос.Заголовки.Вставить("Content-Type",  "application/json; charset=utf-8");
        Запрос.Заголовки.Вставить("Accept",        "application/json");
        Запрос.УстановитьТелоИзСтроки(
            ОбщегоНазначенияСерверПриложение.СериализоватьВJSON(ТелоСтруктура),
            КодировкаТекста.UTF8,
            ИспользованиеByteOrderMark.НеИспользовать);
        
        Ответ = Соединение.ОтправитьДляОбработки(Запрос);
        Результат.КодHTTP = Ответ.КодСостояния;
        
        Если Ответ.КодСостояния >= 200 И Ответ.КодСостояния < 300 Тогда
            ТекстОтвета = Ответ.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
            Результат.ТелоОтвета = ОбщегоНазначенияСерверПриложение.ДесериализоватьИзJSON(ТекстОтвета);
            Результат.Успех = Истина;
        Иначе
            Результат.Ошибка = "HTTP " + Ответ.КодСостояния + ": " + Ответ.ПолучитьТелоКакСтроку();
            ОбщегоНазначенияСерверПриложение.ЗафиксироватьСбой(
                "КлиентIRTСервиса.ВыполнитьЗапрос",
                Результат.Ошибка);
        КонецЕсли;
        
    Исключение
        Результат.Ошибка = ОписаниеОшибки();
        ОбщегоНазначенияСерверПриложение.ЗафиксироватьСбой(
            "КлиентIRTСервиса.ВыполнитьЗапрос",
            "Запрос к " + Эндпоинт + " завершился с ошибкой: " + Результат.Ошибка);
    КонецПопытки;
    
    Возврат Результат;
    
КонецФункции

// Разбирает URL вида "https://host:port/base" в структуру.
//
Функция РазобратьURL(Знач URL)
    
    Результат = Новый Структура;
    Результат.Вставить("Защищённое", Ложь);
    Результат.Вставить("Хост",       "");
    Результат.Вставить("Порт",       80);
    Результат.Вставить("Путь",       "");
    Текст = URL;
    
    Если СтрНачинаетсяС(Текст, "https://") Тогда
        Результат.Защищённое = Истина;
        Результат.Порт = 443;
        Текст = Сред(Текст, СтрДлина("https://") + 1);
    ИначеЕсли СтрНачинаетсяС(Текст, "http://") Тогда
        Результат.Защищённое = Ложь;
        Результат.Порт = 80;
        Текст = Сред(Текст, СтрДлина("http://") + 1);
    КонецЕсли;
    
    ПозицияСлэша = СтрНайти(Текст, "/");
    Если ПозицияСлэша > 0 Тогда
        ХостПорт = Лев(Текст, ПозицияСлэша - 1);
        Результат.Путь = Сред(Текст, ПозицияСлэша);
        Если СтрЗаканчиваетсяНа(Результат.Путь, "/") Тогда
            Результат.Путь = Лев(Результат.Путь, СтрДлина(Результат.Путь) - 1);
        КонецЕсли;
    Иначе
        ХостПорт = Текст;
        Результат.Путь = "";
    КонецЕсли;
    
    ПозицияДвоеточия = СтрНайти(ХостПорт, ":");
    Если ПозицияДвоеточия > 0 Тогда
        Результат.Хост = Лев(ХостПорт, ПозицияДвоеточия - 1);
        Результат.Порт = Число(Сред(ХостПорт, ПозицияДвоеточия + 1));
    Иначе
        Результат.Хост = ХостПорт;
    КонецЕсли;
    
    Возврат Результат;
    
КонецФункции

#КонецОбласти
