#Область ПрограммныйИнтерфейс

// Рекомендует следующую тему обучающемуся в рамках курса.
// Логика: ищется первая тема с не достигнутым порогом θ и со всеми выполненными пререквизитами.
//
// Параметры:
//  Пользователь - Строка - ФИО обучающегося.
//  Курс         - СправочникСсылка.Курсы - курс обучения.
//
// Возвращаемое значение:
//  СправочникСсылка.Темы, Неопределено - рекомендуемая тема или Неопределено.
//
Функция РекомендоватьСледующуюТему(Знач Пользователь, Знач Курс) Экспорт
    
    ПорогТета = ОбщегоНазначенияСерверПриложение.ЗначениеКонстанты("ПорогТетаДляПрохожденияТемы");
    
    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   Темы.Ссылка                            КАК Тема,
        |   Темы.ПорядокИзучения                   КАК ПорядокИзучения,
        |   ЕСТЬNULL(СрезПоследних.Тета, -99)      КАК ТекущаяТета
        |ИЗ
        |   Справочник.Темы КАК Темы
        |   ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОценкиПодготовленностиПоТемам.СрезПоследних(, Пользователь = &Пользователь) КАК СрезПоследних
        |       ПО СрезПоследних.Тема = Темы.Ссылка
        |ГДЕ
        |   Темы.Владелец = &Курс
        |   И НЕ Темы.ПометкаУдаления
        |УПОРЯДОЧИТЬ ПО Темы.ПорядокИзучения");
    Запрос.УстановитьПараметр("Пользователь", Пользователь);
    Запрос.УстановитьПараметр("Курс",         Курс);
    
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Если Выборка.ТекущаяТета < ПорогТета Тогда
            Возврат Выборка.Тема;
        КонецЕсли;
    КонецЦикла;
    
    Возврат Неопределено;
    
КонецФункции

// Рекомендует следующее задание для обучающегося в указанной теме.
//
// Параметры:
//  Пользователь - Строка - ФИО обучающегося.
//  Тема         - СправочникСсылка.Темы - тема.
//
// Возвращаемое значение:
//  СправочникСсылка.ТестовыеЗадания, Неопределено - рекомендуемое задание или Неопределено.
//
Функция РекомендоватьСледующееЗадание(Знач Пользователь, Знач Тема) Экспорт
    
    // Получить текущую θ
    ТекущаяТета = ПолучитьТекущуюТета(Пользователь, Тема);
    
    // Получить уже использованные задания (хотя бы в одной завершённой сессии)
    Использованные = ПолучитьИспользованныеЗадания(Пользователь, Тема);
    
    Кандидаты = АдаптивноеТестирование.ПолучитьКандидатовЗаданийПоТеме(Тема);
    Возврат АдаптивноеТестированиеЛокально.ВыбратьЗаданиеЛокально(
        Кандидаты, ТекущаяТета, Использованные);
    
КонецФункции

// Перестраивает индивидуальную траекторию обучения по курсу и записывает её в регистр.
//
// Параметры:
//  Пользователь - Строка - ФИО обучающегося.
//  Курс         - СправочникСсылка.Курсы - курс обучения.
//
Процедура ПересобратьТраекторию(Знач Пользователь, Знач Курс) Экспорт
    
    Темы = Новый Массив;
    
    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   Темы.Ссылка                       КАК Тема,
        |   ЕСТЬNULL(СрезПоследних.Тета, -99) КАК Тета
        |ИЗ
        |   Справочник.Темы КАК Темы
        |   ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОценкиПодготовленностиПоТемам.СрезПоследних(, Пользователь = &Пользователь) КАК СрезПоследних
        |       ПО СрезПоследних.Тема = Темы.Ссылка
        |ГДЕ
        |   Темы.Владелец = &Курс
        |УПОРЯДОЧИТЬ ПО Темы.ПорядокИзучения");
    Запрос.УстановитьПараметр("Пользователь", Пользователь);
    Запрос.УстановитьПараметр("Курс",         Курс);
    
    ПорогТета = ОбщегоНазначенияСерверПриложение.ЗначениеКонстанты("ПорогТетаДляПрохожденияТемы");
    Выборка = Запрос.Выполнить().Выбрать();
    ВсегоТем = 0;
    Завершено = 0;
    ТекущаяТема = Неопределено;
    Пока Выборка.Следующий() Цикл
        ВсегоТем = ВсегоТем + 1;
        Стр = Новый Структура("Тема, Тета, Завершена", Строка(Выборка.Тема), Выборка.Тета, Выборка.Тета >= ПорогТета);
        Темы.Добавить(Стр);
        Если Выборка.Тета >= ПорогТета Тогда
            Завершено = Завершено + 1;
        ИначеЕсли ТекущаяТема = Неопределено Тогда
            ТекущаяТема = Выборка.Тема;
        КонецЕсли;
    КонецЦикла;
    
    План = Новый Структура("Темы, Создано", Темы, ТекущаяДатаСеанса());
    JSON = ОбщегоНазначенияСерверПриложение.СериализоватьВJSON(План);
    
    НаборЗаписей = РегистрыСведений.СостояниеТраекторииОбучения.СоздатьНаборЗаписей();
    НаборЗаписей.Отбор.Пользователь.Установить(Пользователь);
    НаборЗаписей.Отбор.Курс.Установить(Курс);
    Запись = НаборЗаписей.Добавить();
    Запись.Пользователь       = Пользователь;
    Запись.Курс               = Курс;
    Запись.ОбновлённыйПлан    = JSON;
    Запись.ТекущаяТема        = ТекущаяТема;
    ПроцентЗавершения = 0;
    Если ВсегоТем > 0 Тогда
        ПроцентЗавершения = Завершено * 100.0 / ВсегоТем;
    КонецЕсли;
    Запись.ПроцентЗавершения  = ПроцентЗавершения;
    НаборЗаписей.Записать(Истина);
    
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПолучитьТекущуюТета(Знач Пользователь, Знач Тема)
    
    Запрос = Новый Запрос(
        "ВЫБРАТЬ ПЕРВЫЕ 1 СрезПоследних.Тета
        |ИЗ РегистрСведений.ОценкиПодготовленностиПоТемам.СрезПоследних(, Пользователь = &Пользователь И Тема = &Тема) КАК СрезПоследних");
    Запрос.УстановитьПараметр("Пользователь", Пользователь);
    Запрос.УстановитьПараметр("Тема",         Тема);
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Тета;
    КонецЕсли;
    Возврат 0;

КонецФункции

Функция ПолучитьИспользованныеЗадания(Знач Пользователь, Знач Тема)
    
    Результат = Новый Соответствие;
    Запрос = Новый Запрос(
        "ВЫБРАТЬ РАЗЛИЧНЫЕ Ответы.Задание
        |ИЗ Документ.ПопыткаТеста.Ответы КАК Ответы
        |ГДЕ Ответы.Ссылка.Обучающийся = &Пользователь И Ответы.Ссылка.Тема = &Тема");
    Запрос.УстановитьПараметр("Пользователь", Пользователь);
    Запрос.УстановитьПараметр("Тема",         Тема);
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Результат.Вставить(Выборка.Задание, Истина);
    КонецЦикла;
    Возврат Результат;
    
КонецФункции

#КонецОбласти
