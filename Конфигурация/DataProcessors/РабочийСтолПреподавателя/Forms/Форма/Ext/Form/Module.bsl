#Область ОбработчикиСобытийФормы

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОткрытьДашбордВыполнить(Команда)

	Если Не ЗначениеЗаполнено(ВыбраннаяГруппа) Тогда
		
		ПоказатьСообщениеПользователю(НСтр("ru = 'Выберите учебную группу.'"));
		Возврат;
	КонецЕсли;

	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("УчебнаяГруппа", ВыбраннаяГруппа);
	ОткрытьФорму("Отчет.ДашбордПреподавателя.Форма.ФормаОтчёта", ПараметрыФормы);

КонецПроцедуры

&НаКлиенте
Процедура ОткрытьПользователейВыполнить(Команда)

	ОткрытьФорму("Справочник.Пользователи.ФормаСписка");

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьРейтингВыполнить(Команда)

	Если Не ЗначениеЗаполнено(ВыбраннаяГруппа) Тогда
		
		ПоказатьСообщениеПользователю(НСтр("ru = 'Выберите учебную группу.'"));
		Возврат;
	КонецЕсли;
	
	ОбновитьРейтингНаСервере(ВыбраннаяГруппа);
	ПоказатьСообщениеПользователю(НСтр("ru = 'Рейтинг обновлён.'"));

КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьКалибровкуВыполнить(Команда)

	ПоказатьВопрос(Новый ОписаниеОповещения("ЗапуститьКалибровкуЗавершение", ЭтотОбъект),
		НСтр("ru = 'Запустить калибровку банка заданий? Операция может занять несколько минут.'"),
		РежимДиалогаВопрос.ДаНет);

КонецПроцедуры

&НаКлиенте
Процедура ЗапуститьКалибровкуЗавершение(Ответ, ДополнительныеПараметры) Экспорт

	Если Ответ = КодВозвратаДиалога.Да Тогда
		
		ЗапуститьКалибровкуНаСервере();
		ПоказатьСообщениеПользователю(НСтр("ru = 'Калибровка инициирована.'"));
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
Процедура ОбновитьРейтингНаСервере(Знач ВыбраннаяГруппа)

	Геймификация.ОбновитьРейтинг(ВыбраннаяГруппа);

КонецПроцедуры

&НаСервереБезКонтекста
Процедура ЗапуститьКалибровкуНаСервере()

	// Заглушка — реальная процедура будет в этапе 11 (регламентные задания)
	ОбщегоНазначенияСерверПриложение.ЗафиксироватьСобытие(
		"РабочийСтолПреподавателя", 
		"Запрошена калибровка банка через рабочий стол.");

КонецПроцедуры

&НаКлиенте
Процедура ПоказатьСообщениеПользователю(Знач Текст)

	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = Текст;
	Сообщение.Сообщить();

КонецПроцедуры

#КонецОбласти
