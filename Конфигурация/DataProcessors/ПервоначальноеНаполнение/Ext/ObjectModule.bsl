Функция СоздатьВходДемо(Знач ПользовательСсылка, Знач Логин, Знач Пароль, Знач ИмяРоли)

    ПользовательИБ = Неопределено;
    Для Каждого СуществующийИБ Из ПользователиИнформационнойБазы.ПолучитьПользователей() Цикл
        Если СуществующийИБ.Имя = Логин Тогда
            ПользовательИБ = СуществующийИБ;
            Прервать;
        КонецЕсли;
    КонецЦикла;
    Если ПользовательИБ = Неопределено Тогда
        ПользовательИБ = ПользователиИнформационнойБазы.СоздатьПользователя();
    КонецЕсли;
    ПользовательИБ.Имя                     = Логин;
    ПользовательИБ.ПолноеИмя               = Строка(ПользовательСсылка);
    ПользовательИБ.АутентификацияСтандартная = Истина;
    ПользовательИБ.ПоказыватьВСпискеВыбора  = Истина;
    ПользовательИБ.Пароль                   = Пароль;
    ПользовательИБ.Роли.Очистить();
    РольМетаданных = Метаданные.Роли.Найти(ИмяРоли);
    Если РольМетаданных <> Неопределено Тогда
        ПользовательИБ.Роли.Добавить(РольМетаданных);
    КонецЕсли;
    ПользовательИБ.Записать();

    Объект = ПользовательСсылка.ПолучитьОбъект();
    Объект.ИмяПользователяИБ           = Логин;
    Объект.ИдентификаторПользователяИБ = Строка(ПользователиИБИдентификатор(ПользовательИБ));
    Объект.ОбменДанными.Загрузка       = Истина;
    Объект.Записать();

    Возврат Логин + " (" + ИмяРоли + ")";

КонецФункции

