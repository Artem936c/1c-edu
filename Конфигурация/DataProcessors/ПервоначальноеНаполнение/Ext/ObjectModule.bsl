Функция ТемыКурсаСЗаданиями(Знач Курс)

    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   Темы.Ссылка КАК Тема
        |ИЗ Справочник.Темы КАК Темы
        |ГДЕ Темы.Владелец = &Курс И НЕ Темы.ПометкаУдаления
        |УПОРЯДОЧИТЬ ПО Темы.ПорядокИзучения");
    Запрос.УстановитьПараметр("Курс", Курс);
    ВыборкаТем = Запрос.Выполнить().Выбрать();

    Результат = Новый Массив;
    Пока ВыборкаТем.Следующий() Цикл
        Задания = ЗаданияТемыСТрудностью(ВыборкаТем.Тема);
        Если Задания.Количество() = 0 Тогда
            Продолжить;
        КонецЕсли;
        Результат.Добавить(Новый Структура("Ссылка, Задания", ВыборкаТем.Тема, Задания));
    КонецЦикла;
    Возврат Результат;

КонецФункции

Функция ЗаданияТемыСТрудностью(Знач Тема)

    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   Задания.Ссылка                    КАК Ссылка,
        |   ЕСТЬNULL(Параметры.ТрудностьB, 0) КАК B
        |ИЗ
        |   Справочник.ТестовыеЗадания КАК Задания
        |   ЛЕВОЕ СОЕДИНЕНИЕ (
        |       ВЫБРАТЬ Задание КАК Задание, МАКСИМУМ(ВерсияПараметров) КАК Версия
        |       ИЗ РегистрСведений.ПараметрыIRT
        |       СГРУППИРОВАТЬ ПО Задание) КАК МаксВерсия
        |       ПО МаксВерсия.Задание = Задания.Ссылка
        |   ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ПараметрыIRT КАК Параметры
        |       ПО Параметры.Задание = Задания.Ссылка
        |       И Параметры.ВерсияПараметров = МаксВерсия.Версия
        |ГДЕ Задания.Тема = &Тема И НЕ Задания.ПометкаУдаления");
    Запрос.УстановитьПараметр("Тема", Тема);
    Выборка = Запрос.Выполнить().Выбрать();

    Результат = Новый Массив;
    Пока Выборка.Следующий() Цикл
        Результат.Добавить(Новый Структура("Ссылка, B", Выборка.Ссылка, Выборка.B));
    КонецЦикла;
    Возврат Результат;

КонецФункции

Функция СпособностьСтудента(Знач Индекс, ГСЧ)

    // Базовая подготовленность: равномерный разброс от -1.0 до +1.3 по индексу
    // плюс небольшой шум - чтобы рейтинг и тепловая карта были разнообразными.
    База = -1.0 + Индекс * (2.3 / 23.0);
    Возврат База + СлучайноеНормальное(ГСЧ, 0, 0.2);

КонецФункции

Функция СлучайноеРавномерное(ГСЧ, Знач Мин, Знач Макс)

    Доля = ГСЧ.СлучайноеЧисло(0, 1000000000) / 1000000000;
    Возврат Мин + (Макс - Мин) * Доля;

КонецФункции

Функция СлучайноеНормальное(ГСЧ, Знач Среднее, Знач Сигма)

    У1 = Макс(0.0000001, СлучайноеРавномерное(ГСЧ, 0, 1));
    У2 = СлучайноеРавномерное(ГСЧ, 0, 1);
    Z  = Sqrt(-2 * Log(У1)) * Cos(2 * 3.141592653589793 * У2);
    Возврат Среднее + Сигма * Z;

КонецФункции

Функция СкопироватьМассив(Знач Исходный)

    Копия = Новый Массив;
    Для Каждого Элемент Из Исходный Цикл
        Копия.Добавить(Элемент);
    КонецЦикла;
    Возврат Копия;

КонецФункции

Процедура ПеремешатьМассив(Массив, ГСЧ)

    Всего = Массив.Количество();
    Если Всего < 2 Тогда
        Возврат;
    КонецЕсли;
    Для Индекс = 0 По Всего - 2 Цикл
        Диапазон = Всего - Индекс;
        Смещение = Цел(СлучайноеРавномерное(ГСЧ, 0, Диапазон));
        Если Смещение >= Диапазон Тогда
            Смещение = Диапазон - 1;
        КонецЕсли;
        ИндексJ        = Индекс + Смещение;
        Временное      = Массив[Индекс];
        Массив[Индекс] = Массив[ИндексJ];
        Массив[ИндексJ] = Временное;
    КонецЦикла;

КонецПроцедуры

Процедура СоздатьПрактическиеЗаданияИПроверки(Знач Студенты, Знач Темы, Знач Сегодня)

    Если Темы.Количество() = 0 Тогда
        Возврат;
    КонецЕсли;
    ТемаЗадания = Темы[0].Ссылка;

    ЧеклистСправочник = "{""ОбязательныеПроцедуры"":[""ПередЗаписью""],"
        + """ОбязательныеКонструкции"":[""ИНН"",""Справочник""],"
        + """ЗапрещенныеКонструкции"":[""Сообщить(""]}";
    Задание1 = СоздатьПрактЗадание(ТемаЗадания,
        "Создать справочник Контрагенты с реквизитом ИНН и обработчиком ПередЗаписью",
        ЧеклистСправочник);

    ЧеклистЗапрос = "{""ОбязательныеКонструкции"":[""ВЫБРАТЬ"",""ИЗ"",""ГДЕ""],""ЗапрещенныеКонструкции"":[]}";
    Задание2 = СоздатьПрактЗадание(ТемаЗадания,
        "Написать запрос выборки номенклатуры по артикулу",
        ЧеклистЗапрос);

    КодХороший =
        "// Обработчик справочника Контрагенты" + Символы.ПС
        + "Процедура ПередЗаписью(Отказ) Экспорт" + Символы.ПС
        + "    Если ПустаяСтрока(ИНН) Тогда" + Символы.ПС
        + "        Отказ = Истина;" + Символы.ПС
        + "    КонецЕсли;" + Символы.ПС
        + "КонецПроцедуры";

    КодСОшибкой =
        "Функция ПроверитьИНН()" + Символы.ПС
        + "    Сообщить(""проверка"");" + Символы.ПС
        + "    Если Истина Тогда" + Символы.ПС
        + "        Возврат Ложь;" + Символы.ПС
        + "КонецФункции";

    КодЗапрос =
        "ВЫБРАТЬ Ссылка ИЗ Справочник.Номенклатура ГДЕ Артикул = &Артикул";

    Выполнение1 = СоздатьВыполнение(Студенты[0], Задание1, КодХороший, Сегодня - 2 * 86400);
    ПроверкаПрактическихЗаданий.ПроверитьВыполнение(Выполнение1);

    Выполнение2 = СоздатьВыполнение(Студенты[3], Задание1, КодСОшибкой, Сегодня - 86400);
    ПроверкаПрактическихЗаданий.ПроверитьВыполнение(Выполнение2);

    Выполнение3 = СоздатьВыполнение(Студенты[1], Задание2, КодЗапрос, Сегодня - 86400);
    ПроверкаПрактическихЗаданий.ПроверитьВыполнение(Выполнение3);

КонецПроцедуры

Функция СоздатьПрактЗадание(Знач Тема, Знач Формулировка, Знач ЧеклистJSON)

