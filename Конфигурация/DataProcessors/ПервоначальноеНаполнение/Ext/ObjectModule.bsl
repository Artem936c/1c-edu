#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ПрограммныйИнтерфейс

// Идемпотентно наполняет справочники конфигурации эталонными данными из JSON-файлов.
//
// Параметры:
//  КаталогФикстур - Строка - путь к каталогу fixtures (содержащему courses_seed.json,
//                            badges_seed.json, library_seed.json и подкаталог question_bank).
//
// Возвращаемое значение:
//  Структура:
//   * Курсы     - Число  - количество загруженных курсов.
//   * Темы      - Число  - количество загруженных тем.
//   * Задания   - Число  - количество загруженных заданий.
//   * Бейджи    - Число  - количество загруженных бейджей.
//   * Материалы - Число  - количество загруженных материалов библиотеки.
//   * Ошибка    - Строка - текст ошибки (пустая строка при успехе).
//
// Пример вызова:
//  Результат = Обработки.ПервоначальноеНаполнение.Создать().ВыполнитьНаполнение("C:/repo/Конфигурация/fixtures");
//
Функция ВыполнитьНаполнение(Знач КаталогФикстур = "") Экспорт

    Результат = Новый Структура;
    Результат.Вставить("Курсы",     0);
    Результат.Вставить("Темы",      0);
    Результат.Вставить("Задания",   0);
    Результат.Вставить("Бейджи",    0);
    Результат.Вставить("Материалы", 0);
    Результат.Вставить("Ошибка",    "");

    Попытка
        Каталог = НормализоватьКаталог(КаталогФикстур);

        КартаТем = ЗагрузитьКурсИТемы(Каталог, Результат);
        Если КартаТем = Неопределено Тогда
            КартаТем = Новый Соответствие;
        КонецЕсли;

        ЗагрузитьБанкЗаданий(Каталог, КартаТем, Результат);
        ЗагрузитьБейджи(Каталог, Результат);
        ЗагрузитьБиблиотеку(Каталог, КартаТем, Результат);

        ОбщегоНазначенияСерверПриложение.ЗафиксироватьСобытие(
            "ПервоначальноеНаполнение",
            СтрШаблон(
                "Наполнение завершено. Курсы: %1, темы: %2, задания: %3, бейджи: %4, материалы: %5",
                Результат.Курсы, Результат.Темы, Результат.Задания,
                Результат.Бейджи, Результат.Материалы));

    Исключение
        Результат.Ошибка = ОписаниеОшибки();
        ОбщегоНазначенияСерверПриложение.ЗафиксироватьСбой(
            "ПервоначальноеНаполнение", Результат.Ошибка);
    КонецПопытки;

    Возврат Результат;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Загружает курс и его темы. Возвращает соответствие «код темы -> ссылка».
//
Функция ЗагрузитьКурсИТемы(Знач Каталог, Результат)

    Данные = ПрочитатьJSONФайл(Каталог + "courses_seed.json");
    Если Данные = Неопределено Тогда
        Возврат Неопределено;
    КонецЕсли;

    КурсДанные = Данные.Получить("курс");
    КодКурса = КурсДанные.Получить("код");
    КурсСсылка = Справочники.Курсы.НайтиПоКоду(КодКурса);
    Если ЗначениеЗаполнено(КурсСсылка) Тогда
        КурсОбъект = КурсСсылка.ПолучитьОбъект();
    Иначе
        КурсОбъект = Справочники.Курсы.СоздатьЭлемент();
        КурсОбъект.Код = КодКурса;
    КонецЕсли;
    КурсОбъект.Наименование     = Усечь(КурсДанные.Получить("наименование"), 150);
    КурсОбъект.ПолноеОписание   = СтрокаИлиПусто(КурсДанные.Получить("полное_описание"));
    КурсОбъект.Преподаватель    = ОбслуживаниеПользователейВызовСервера.НайтиИлиСоздатьПоФИО(
        СтрокаИлиПусто(КурсДанные.Получить("преподаватель")),
        Перечисления.ВидыПользователей.Преподаватель);
    КурсОбъект.ЦелеваяАудитория  = СтрокаИлиПусто(КурсДанные.Получить("целевая_аудитория"));
    КурсОбъект.ДатаНачала       = ДатаИзСтроки(КурсДанные.Получить("дата_начала"));
    КурсОбъект.ДатаОкончания    = ДатаИзСтроки(КурсДанные.Получить("дата_окончания"));
    КурсОбъект.Записать();
    Курс = КурсОбъект.Ссылка;
    Результат.Курсы = Результат.Курсы + 1;

    КартаТем = Новый Соответствие;
    ТемыМассив = Данные.Получить("темы");

    // Первый проход — создание тем.
    Для Каждого ТемаДанные Из ТемыМассив Цикл
        КодТемы = ТемаДанные.Получить("код");
        ТемаСсылка = Справочники.Темы.НайтиПоКоду(КодТемы, Ложь, , Курс);
        Если ЗначениеЗаполнено(ТемаСсылка) Тогда
            ТемаОбъект = ТемаСсылка.ПолучитьОбъект();
        Иначе
            ТемаОбъект = Справочники.Темы.СоздатьЭлемент();
            ТемаОбъект.Код = КодТемы;
            ТемаОбъект.Владелец = Курс;
        КонецЕсли;
        ТемаОбъект.Наименование    = Усечь(ТемаДанные.Получить("наименование"), 100);
        ТемаОбъект.Описание        = СтрокаИлиПусто(ТемаДанные.Получить("описание"));
        ТемаОбъект.Сложность       = ЧислоИлиНоль(ТемаДанные.Получить("сложность"));
        ТемаОбъект.ПорядокИзучения = ЧислоИлиНоль(ТемаДанные.Получить("порядок"));
        ТемаОбъект.Записать();
        КартаТем.Вставить(КодТемы, ТемаОбъект.Ссылка);
        Результат.Темы = Результат.Темы + 1;
    КонецЦикла;

    // Второй проход — привязка пререквизитов (ссылки на ранее созданные темы).
    Для Каждого ТемаДанные Из ТемыМассив Цикл
        Пререквизиты = ТемаДанные.Получить("пререквизиты");
        Если Пререквизиты = Неопределено Или Пререквизиты.Количество() = 0 Тогда
            Продолжить;
        КонецЕсли;
        ТемаОбъект = КартаТем.Получить(ТемаДанные.Получить("код")).ПолучитьОбъект();
        ТемаОбъект.Пререквизиты.Очистить();
        Для Каждого КодПрек Из Пререквизиты Цикл
            ПрекСсылка = КартаТем.Получить(КодПрек);
            Если ЗначениеЗаполнено(ПрекСсылка) Тогда
                СтрокаПрек = ТемаОбъект.Пререквизиты.Добавить();
                СтрокаПрек.Тема = ПрекСсылка;
            КонецЕсли;
        КонецЦикла;
        ТемаОбъект.Записать();
    КонецЦикла;

    Возврат КартаТем;

КонецФункции

// Загружает банк тестовых заданий из шести файлов подкаталога question_bank.
//
Процедура ЗагрузитьБанкЗаданий(Знач Каталог, Знач КартаТем, Результат)

    Файлы = Новый Массив;
    Файлы.Добавить("metadata.json");
    Файлы.Добавить("query_language.json");
    Файлы.Добавить("builtin_language.json");
    Файлы.Добавить("forms_ui.json");
    Файлы.Добавить("extensions.json");
    Файлы.Добавить("exchange.json");

    Для Каждого ИмяФайла Из Файлы Цикл
        Данные = ПрочитатьJSONФайл(Каталог + "question_bank/" + ИмяФайла);
        Если Данные = Неопределено Тогда
            Продолжить;
        КонецЕсли;
        ТемаСсылка = КартаТем.Получить(Данные.Получить("код_темы"));
        Если Не ЗначениеЗаполнено(ТемаСсылка) Тогда
            Продолжить;
        КонецЕсли;
        Для Каждого ЗаданиеДанные Из Данные.Получить("задания") Цикл
            ЗагрузитьОдноЗадание(ЗаданиеДанные, ТемаСсылка, Результат);
        КонецЦикла;
    КонецЦикла;

КонецПроцедуры

// Создаёт или обновляет одно тестовое задание и его стартовые параметры IRT.
//
Процедура ЗагрузитьОдноЗадание(Знач Данные, Знач ТемаСсылка, Результат)

    КодЗадания = Данные.Получить("код");
    ЗаданиеСсылка = Справочники.ТестовыеЗадания.НайтиПоКоду(КодЗадания);
    Если ЗначениеЗаполнено(ЗаданиеСсылка) Тогда
        Объект = ЗаданиеСсылка.ПолучитьОбъект();
    Иначе
        Объект = Справочники.ТестовыеЗадания.СоздатьЭлемент();
        Объект.Код = КодЗадания;
    КонецЕсли;

    Объект.Наименование         = Усечь(Данные.Получить("наименование"), 150);
    Объект.Тема                 = ТемаСсылка;
    Объект.ТипЗадания           = Перечисления.ТипыТестовыхЗаданий[Данные.Получить("тип")];
    Объект.Формулировка         = СтрокаИлиПусто(Данные.Получить("формулировка"));
    Объект.КонтекстПредъявления = СтрокаИлиПусто(Данные.Получить("контекст"));
    Объект.ВерсияПараметров     = 0;
    Объект.ВидимыйСтатус        = Истина;

    Объект.ВариантыОтвета.Очистить();
    Варианты = Данные.Получить("варианты");
    Если Варианты <> Неопределено Тогда
        Для Каждого Вариант Из Варианты Цикл
            Строка = Объект.ВариантыОтвета.Добавить();
            Строка.Текст = СтрокаИлиПусто(Вариант.Получить("текст"));
            Строка.ЯвляетсяПравильным = (Вариант.Получить("правильный") = Истина);
        КонецЦикла;
    КонецЕсли;

    Объект.ЭталонныйОтвет.Очистить();
    Эталон = Данные.Получить("эталон");
    Если Эталон <> Неопределено Тогда
        Для Каждого ЭлементЭталона Из Эталон Цикл
            Строка = Объект.ЭталонныйОтвет.Добавить();
            Строка.Текст = СтрокаИлиПусто(ЭлементЭталона.Получить("текст"));
            Строка.Тип   = Усечь(ЭлементЭталона.Получить("тип"), 50);
        КонецЦикла;
    КонецЕсли;

    Объект.Записать();
    Результат.Задания = Результат.Задания + 1;

    ЗначениеA = Данные.Получить("a");
    Если ЗначениеA = Неопределено Тогда
        ЗначениеA = 1;
    КонецЕсли;
    ЗаписатьСтартовыеПараметры(Объект.Ссылка, ЧислоИлиНоль(Данные.Получить("b")), Число(ЗначениеA));

КонецПроцедуры

// Записывает стартовые параметры IRT (версия 0, статус «Не калибровано»).
//
Процедура ЗаписатьСтартовыеПараметры(Знач Задание, Знач ТрудностьB, Знач ДискриминативностьA)

    НаборЗаписей = РегистрыСведений.ПараметрыIRT.СоздатьНаборЗаписей();
    НаборЗаписей.Отбор.Задание.Установить(Задание);
    НаборЗаписей.Отбор.ВерсияПараметров.Установить(0);
    Запись = НаборЗаписей.Добавить();
    Запись.Задание              = Задание;
    Запись.ВерсияПараметров     = 0;
    Запись.ТрудностьB           = ТрудностьB;
    Запись.ДискриминативностьA  = ДискриминативностьA;
    Запись.СтатусКалибровки     = Перечисления.СтатусыКалибровкиЗадания.НеКалибровано;
    Запись.ДатаКалибровки       = ТекущаяДатаСеанса();
    Запись.ЧислоОтветовВВыборке = 0;
    НаборЗаписей.Записать(Истина);

КонецПроцедуры

// Загружает бейджи с условиями активации.
//
Процедура ЗагрузитьБейджи(Знач Каталог, Результат)

    Данные = ПрочитатьJSONФайл(Каталог + "badges_seed.json");
    Если Данные = Неопределено Тогда
        Возврат;
    КонецЕсли;

    Для Каждого БейджДанные Из Данные.Получить("бейджи") Цикл
        Код = БейджДанные.Получить("код");
        Ссылка = Справочники.Бейджи.НайтиПоКоду(Код);
        Если ЗначениеЗаполнено(Ссылка) Тогда
            Объект = Ссылка.ПолучитьОбъект();
        Иначе
            Объект = Справочники.Бейджи.СоздатьЭлемент();
            Объект.Код = Код;
        КонецЕсли;
        Объект.Наименование    = Усечь(БейджДанные.Получить("наименование"), 100);
        Объект.Категория       = Перечисления.КатегорииБейджей[БейджДанные.Получить("категория")];
        Объект.Описание        = СтрокаИлиПусто(БейджДанные.Получить("описание"));
        Объект.БаллыЗаПолучение = ЧислоИлиНоль(БейджДанные.Получить("баллы"));

        Объект.УсловияАктивации.Очистить();
        Условия = БейджДанные.Получить("условия");
        Если Условия <> Неопределено Тогда
            Для Каждого Условие Из Условия Цикл
                Строка = Объект.УсловияАктивации.Добавить();
                Строка.ТипУсловия        = СтрокаИлиПусто(Условие.Получить("тип"));
                Строка.Параметр          = СтрокаИлиПусто(Условие.Получить("параметр"));
                Строка.ПороговоеЗначение = ЧислоИлиНоль(Условие.Получить("порог"));
            КонецЦикла;
        КонецЕсли;
        Объект.Записать();
        Результат.Бейджи = Результат.Бейджи + 1;
    КонецЦикла;

КонецПроцедуры

// Загружает материалы библиотеки с привязками к темам.
//
Процедура ЗагрузитьБиблиотеку(Знач Каталог, Знач КартаТем, Результат)

    Данные = ПрочитатьJSONФайл(Каталог + "library_seed.json");
    Если Данные = Неопределено Тогда
        Возврат;
    КонецЕсли;

    Для Каждого МатериалДанные Из Данные.Получить("материалы") Цикл
        Код = МатериалДанные.Получить("код");
        Ссылка = Справочники.МатериалыБиблиотеки.НайтиПоКоду(Код);
        Если ЗначениеЗаполнено(Ссылка) Тогда
            Объект = Ссылка.ПолучитьОбъект();
        Иначе
            Объект = Справочники.МатериалыБиблиотеки.СоздатьЭлемент();
            Объект.Код = Код;
        КонецЕсли;
        Объект.Наименование              = Усечь(МатериалДанные.Получить("наименование"), 150);
        Объект.ВидМатериала              = Перечисления.ВидыМатериаловБиблиотеки[МатериалДанные.Получить("вид")];
        Объект.БиблиографическоеОписание = СтрокаИлиПусто(МатериалДанные.Получить("библиография"));
        Объект.КраткоеОписание           = СтрокаИлиПусто(МатериалДанные.Получить("краткое_описание"));
        Объект.КлючевыеСлова             = СтрокаИлиПусто(МатериалДанные.Получить("ключевые_слова"));
        Объект.Автор                     = СтрокаИлиПусто(МатериалДанные.Получить("автор"));
        Объект.ГодИздания                = ЧислоИлиНоль(МатериалДанные.Получить("год"));
        Объект.Издательство              = СтрокаИлиПусто(МатериалДанные.Получить("издательство"));
        Объект.ISBN                      = СтрокаИлиПусто(МатериалДанные.Получить("isbn"));

        ИмяФайлаОтн = СтрокаИлиПусто(МатериалДанные.Получить("файл"));
        Если ЗначениеЗаполнено(ИмяФайлаОтн) Тогда
            ЗагрузитьФайлКниги(Объект, Каталог + ИмяФайлаОтн);
        КонецЕсли;

        Объект.ПривязкиКТемам.Очистить();
        ТемыКоды = МатериалДанные.Получить("темы");
        Приоритет = 1;
        Если ТемыКоды <> Неопределено Тогда
            Для Каждого КодТемы Из ТемыКоды Цикл
                ТемаСсылка = КартаТем.Получить(КодТемы);
                Если ЗначениеЗаполнено(ТемаСсылка) Тогда
                    Строка = Объект.ПривязкиКТемам.Добавить();
                    Строка.Тема = ТемаСсылка;
                    Строка.Приоритет = Приоритет;
                    Приоритет = Приоритет + 1;
                КонецЕсли;
            КонецЦикла;
        КонецЕсли;
        Объект.Записать();
        Результат.Материалы = Результат.Материалы + 1;
    КонецЦикла;

КонецПроцедуры

// --- Вспомогательные функции ---

// Читает файл книги с диска и помещает его в реквизит ФайлКниги
// (ХранилищеЗначения). ИмяФайлаКниги - исходное имя файла. Дополнительно грузит
// предрендеренные PNG-страницы (для просмотра внутри программы).
//
Процедура ЗагрузитьФайлКниги(Объект, Знач Путь)

    Файл = Новый Файл(Путь);
    Если Не Файл.Существует() Тогда
        ОбщегоНазначенияСерверПриложение.ЗафиксироватьСбой(
            "ПервоначальноеНаполнение", "Файл книги не найден: " + Путь);
        Возврат;
    КонецЕсли;

    ДвоичныеДанные = Новый ДвоичныеДанные(Путь);
    Объект.ФайлКниги     = Новый ХранилищеЗначения(ДвоичныеДанные);
    Объект.ИмяФайлаКниги = Файл.Имя;

    ЗагрузитьСтраницыКниги(Объект, Файл);

КонецПроцедуры

// Грузит предрендеренные PNG-страницы книги в реквизит СтраницыКниги (массив
// ДвоичныхДанных в ХранилищеЗначения). Страницы лежат в папке рядом с PDF:
// <имя-pdf-без-расширения>/page-NNN.png (готовятся скриптом
// fixtures/books/render_pdf_pages.mjs). Если папки/страниц нет - реквизит пуст,
// просмотрщик покажет заглушку.
//
Процедура ЗагрузитьСтраницыКниги(Объект, Знач ФайлPDF)

    ПапкаСтраниц = ФайлPDF.Путь + ФайлPDF.ИмяБезРасширения;
    НайденныеФайлы = НайтиФайлы(ПапкаСтраниц, "page-*.png");

    Если НайденныеФайлы.Количество() = 0 Тогда
        Возврат;
    КонецЕсли;

    // НайтиФайлы не гарантирует порядок - сортируем по имени (page-001, page-002, ...).
    СписокИмен = Новый СписокЗначений;
    Для Каждого Ф Из НайденныеФайлы Цикл
        СписокИмен.Добавить(Ф.ПолноеИмя);
    КонецЦикла;
    СписокИмен.СортироватьПоЗначению();
    Имена = СписокИмен.ВыгрузитьЗначения();

    Страницы = Новый Массив;
    Для Каждого ПолноеИмя Из Имена Цикл
        Страницы.Добавить(Новый ДвоичныеДанные(ПолноеИмя));
    КонецЦикла;

    Объект.СтраницыКниги = Новый ХранилищеЗначения(Страницы);

КонецПроцедуры

Функция ПрочитатьJSONФайл(Знач Путь)

    Файл = Новый Файл(Путь);
    Если Не Файл.Существует() Тогда
        ОбщегоНазначенияСерверПриложение.ЗафиксироватьСбой(
            "ПервоначальноеНаполнение", "Файл эталонных данных не найден: " + Путь);
        Возврат Неопределено;
    КонецЕсли;

    Чтение = Новый ЧтениеТекста(Путь, КодировкаТекста.UTF8);
    Текст = Чтение.Прочитать();
    Чтение.Закрыть();

    Возврат ОбщегоНазначенияСерверПриложение.ДесериализоватьИзJSON(Текст);

КонецФункции

Функция НормализоватьКаталог(Знач Каталог)

    Если Не ЗначениеЗаполнено(Каталог) Тогда
        ВызватьИсключение "Не указан каталог с файлами эталонных данных (fixtures).";
    КонецЕсли;
    Стр = СтрЗаменить(Каталог, "\", "/");
    Если Прав(Стр, 1) <> "/" Тогда
        Стр = Стр + "/";
    КонецЕсли;
    Возврат Стр;

КонецФункции

Функция ДатаИзСтроки(Знач Значение)

    Если Не ЗначениеЗаполнено(Значение) Тогда
        Возврат '00010101';
    КонецЕсли;
    Части = СтрРазделить(Строка(Значение), "-");
    Если Части.Количество() < 3 Тогда
        Возврат '00010101';
    КонецЕсли;
    Возврат Дата(Число(Части[0]), Число(Части[1]), Число(Части[2]));

КонецФункции

Функция ЧислоИлиНоль(Знач Значение)

    Если Значение = Неопределено Тогда
        Возврат 0;
    КонецЕсли;
    Возврат Число(Значение);

КонецФункции

Функция СтрокаИлиПусто(Знач Значение)

    Если Значение = Неопределено Тогда
        Возврат "";
    КонецЕсли;
    Возврат Строка(Значение);

КонецФункции

Функция Усечь(Знач Значение, Знач МаксимальнаяДлина)

    Стр = СтрокаИлиПусто(Значение);
    Если СтрДлина(Стр) > МаксимальнаяДлина Тогда
        Стр = Лев(Стр, МаксимальнаяДлина);
    КонецЕсли;
    Возврат Стр;

КонецФункции

#КонецОбласти

#Область ДемоНаполнение

// Наполняет базу демонстрационными данными для защиты ВКР: устанавливает константы,
// создает преподавателя, учебную группу, 24 обучающихся и их учебную историю за 4 недели
// (попытки тестов, оценки theta, баллы опыта, события аналитики, бейджи, рейтинг), а также
// создает учетные записи входа с ролями. Идемпотентно: при наличии демо-группы повторно
// данные не создаются.
//
// Параметры:
//  КаталогФикстур - Строка - путь к каталогу fixtures (см. ВыполнитьНаполнение).
//
// Возвращаемое значение:
//  Структура - результат ВыполнитьНаполнение, дополненный ключами:
//   * Студенты - Число  - количество созданных обучающихся.
//   * Сессии   - Число  - количество созданных попыток тестирования.
//   * Логины   - Строка - перечень созданных учетных записей входа.
//
Функция ВыполнитьДемоНаполнение(Знач КаталогФикстур = "") Экспорт

    Результат = ВыполнитьНаполнение(КаталогФикстур);
    Результат.Вставить("Студенты", 0);
    Результат.Вставить("Сессии",   0);
    Результат.Вставить("Логины",   "");
    Если Не ПустаяСтрока(Результат.Ошибка) Тогда
        Возврат Результат;
    КонецЕсли;

    Попытка
        УстановитьПривилегированныйРежим(Истина);
        СоздатьДемоДанные(Результат);
    Исключение
        Результат.Ошибка = ОписаниеОшибки();
        ОбщегоНазначенияСерверПриложение.ЗафиксироватьСбой("ДемоНаполнение", Результат.Ошибка);
    КонецПопытки;

    Возврат Результат;

КонецФункции

Процедура СоздатьДемоДанные(Результат)

    УстановитьКонстантыПоУмолчанию();

    Если ДемоГруппаСуществует() Тогда
        Результат.Вставить("Сообщение", "Демо-данные уже созданы ранее");
        Возврат;
    КонецЕсли;

    Курс = ПервыйКурс();
    Если Не ЗначениеЗаполнено(Курс) Тогда
        ВызватьИсключение "Нет курса для демо-наполнения (сначала загрузите фикстуры)";
    КонецЕсли;

    Темы = ТемыКурсаСЗаданиями(Курс);
    Если Темы.Количество() = 0 Тогда
        ВызватьИсключение "Нет тем для демо-наполнения";
    КонецЕсли;

    Сегодня   = НачалоДня(ТекущаяДатаСеанса());
    ДатаСтарт = Сегодня - 28 * 86400;
    ГСЧ       = Новый ГенераторСлучайныхЧисел(20260621);
    ПорогТета = ОбщегоНазначенияСерверПриложение.ЗначениеКонстанты("ПорогТетаДляПрохожденияТемы");

    Преподаватель = СоздатьПользователяДемо("Иванова Мария Петровна", Перечисления.ВидыПользователей.Преподаватель);

    ИменаСтудентов = СписокИменСтудентов();
    Студенты = Новый Массив;
    Группа = Справочники.УчебныеГруппы.СоздатьЭлемент();
    Группа.Наименование  = ДемоГруппаНаименование();
    Группа.Преподаватель = Преподаватель;
    Группа.ГодНабора     = 2025;
    Для Сч = 0 По 23 Цикл
        Студент = СоздатьПользователяДемо(ИменаСтудентов[Сч], Перечисления.ВидыПользователей.Обучающийся);
        Студенты.Добавить(Студент);
        СтрокаСостава = Группа.Состав.Добавить();
        СтрокаСостава.Пользователь    = Студент;
        СтрокаСостава.ДатаЗачисления = ДатаСтарт;
    КонецЦикла;
    Группа.Записать();
    ГруппаСсылка = Группа.Ссылка;

    Для Индекс = 0 По Студенты.Количество() - 1 Цикл
        СоздатьИсториюСтудента(Студенты[Индекс], Индекс, Темы, ДатаСтарт, Сегодня, ГСЧ, ПорогТета, Результат);
    КонецЦикла;

    // Бейджи и траектория - по фактически накопленным метрикам.
    Для Каждого Студент Из Студенты Цикл
        Геймификация.ПроверитьУсловияБейджей(Студент);
        ТраекторияОбучения.ПересобратьТраекторию(Студент, Курс);
    КонецЦикла;

    // Два среза рейтинга (неделю назад и сегодня) - чтобы показать изменение позиции.
    НаписатьРейтингНаДату(ГруппаСсылка, Сегодня - 7 * 86400);
    Геймификация.ОбновитьРейтинг(ГруппаСсылка);

    // Практические задания и автоматически проверенные решения.
    СоздатьПрактическиеЗаданияИПроверки(Студенты, Темы, Сегодня);

    // Учетные записи входа с ролями. Администратора создаем первым: платформа не дает
    // создать первого пользователя ИБ без административных прав.
    // Пароль у каждой учетной записи совпадает с логином (для удобства демонстрации).
    Логины = "";
    Логины = Логины + СоздатьАдминвходДемо() + "; ";
    Логины = Логины + СоздатьВходДемо(Преподаватель, "teacher", "teacher", "Преподаватель") + "; ";
    Логины = Логины + СоздатьВходДемо(Студенты[0], "student", "student", "Обучающийся") + "; ";
    Логины = Логины + СоздатьВходДемо(Студенты[1], "student2", "student2", "Обучающийся");

    Результат.Студенты = Студенты.Количество();
    Результат.Логины   = Логины;

КонецПроцедуры

Процедура УстановитьКонстантыПоУмолчанию()

    УстановитьКонстантуЕслиПусто("URLМикросервисаIRT",         "http://localhost:8001");
    УстановитьКонстантуЕслиПусто("ТаймаутЗапросаКМикросервису", 30);
    УстановитьКонстантуЕслиПусто("ЛимитЗаданийВСессии",         25);
    УстановитьКонстантуЕслиПусто("ЦелеваяСтандартнаяОшибкаТета", 0.30);
    УстановитьКонстантуЕслиПусто("ПорогТетаДляПрохожденияТемы",  0.5);
    УстановитьКонстантуЕслиПусто("ПорогОтветовДляКалибровки",    30);

КонецПроцедуры

Процедура УстановитьКонстантуЕслиПусто(Знач Имя, Знач Значение)

    КонстантаМенеджер = Константы[Имя];
    Если Не ЗначениеЗаполнено(КонстантаМенеджер.Получить()) Тогда
        КонстантаМенеджер.Установить(Значение);
    КонецЕсли;

КонецПроцедуры

Процедура СоздатьИсториюСтудента(Знач Студент, Знач Индекс, Знач Темы, Знач ДатаСтарт,
                                  Знач Сегодня, ГСЧ, Знач ПорогТета, Результат)

    Показательный = (Индекс = 0);
    Способность   = СпособностьСтудента(Индекс, ГСЧ);

    Для Каждого ТемаДанные Из Темы Цикл
        ТемаСсылка = ТемаДанные.Ссылка;
        Задания    = ТемаДанные.Задания;

        ТетаПре = Способность + СлучайноеНормальное(ГСЧ, -0.2, 0.45);
        Прирост = Макс(0.15, Мин(1.6, СлучайноеНормальное(ГСЧ, 0.84, 0.30)));
        ТетаПост = ТетаПре + Прирост;
        Если Показательный Тогда
            ТетаПост = Макс(ТетаПост, 1.3);
        КонецЕсли;
        SEПост = Окр(0.26 + СлучайноеРавномерное(ГСЧ, 0, 0.06), 2);

        ДеньСессии = 14 + Цел(СлучайноеРавномерное(ГСЧ, 0, 13));
        ДатаСессии = ДатаСтарт + ДеньСессии * 86400 + (9 + Индекс % 8) * 3600;

        НаписатьОценку(Студент, ТемаСсылка, ТетаПре,                  0.6, ДатаСтарт + 86400, Неопределено);
        НаписатьОценку(Студент, ТемаСсылка, (ТетаПре + ТетаПост) / 2, 0.4, ДатаСтарт + 14 * 86400, Неопределено);

        Сессия = НаписатьСессию(Студент, ТемаСсылка, ТетаПост, SEПост, ДатаСессии, ГСЧ, Задания);
        НаписатьОценку(Студент, ТемаСсылка, ТетаПост, SEПост, ДатаСессии + 700, Сессия.Ссылка);
        Результат.Сессии = Результат.Сессии + 1;

        НаписатьСобытие(Студент, ТемаСсылка, Перечисления.ТипыСобытийАналитики.ОткрытиеМатериала,   ДатаСессии - 3600);
        НаписатьСобытие(Студент, ТемаСсылка, Перечисления.ТипыСобытийАналитики.НачалоСессииТеста,    ДатаСессии);
        НаписатьСобытие(Студент, ТемаСсылка, Перечисления.ТипыСобытийАналитики.ЗавершениеСессии,     ДатаСессии + 700);

        Если Сессия.Верных > 0 Тогда
            НаписатьНачисление(Студент, ТемаСсылка, Перечисления.ПричиныНачисленияБаллов.ВерныйОтвет,
                Сессия.Верных * 5, ДатаСессии + 720);
        КонецЕсли;
        Если ТетаПост >= ПорогТета Тогда
            НаписатьНачисление(Студент, ТемаСсылка, Перечисления.ПричиныНачисленияБаллов.ЗавершениеТемы,
                20, ДатаСессии + 740);
        КонецЕсли;
    КонецЦикла;

КонецПроцедуры

Функция НаписатьСессию(Знач Студент, Знач Тема, Знач ТетаИтог, Знач SEИтог, Знач Дата, ГСЧ, Знач Задания)

    Сессия = Документы.ПопыткаТеста.СоздатьДокумент();
    Сессия.Дата         = Дата;
    Сессия.Обучающийся  = Студент;
    Сессия.Тема         = Тема;
    Сессия.ДатаНачала   = Дата;

    Колода = СкопироватьМассив(Задания);
    ПеремешатьМассив(Колода, ГСЧ);
    Число = 10 + Цел(СлучайноеРавномерное(ГСЧ, 0, 4));
    Если Число > Колода.Количество() Тогда
        Число = Колода.Количество();
    КонецЕсли;

    Верных       = 0;
    ТекущееВремя = Дата;
    Для Шаг = 1 По Число Цикл
        ЗаданиеДанные = Колода[Шаг - 1];
        B = ЗаданиеДанные.B;
        P = 1 / (1 + Exp(-(ТетаИтог - B)));
        Верно = (СлучайноеРавномерное(ГСЧ, 0, 1) < P);
        Если Верно Тогда
            Верных = Верных + 1;
        КонецЕсли;
        ВремяОтвета  = 25 + Цел(СлучайноеРавномерное(ГСЧ, 0, 90));
        ТекущееВремя = ТекущееВремя + ВремяОтвета;

        Стр = Сессия.Ответы.Добавить();
        Стр.НомерШага         = Шаг;
        Стр.Задание           = ЗаданиеДанные.Ссылка;
        Стр.Верно             = Верно;
        Стр.Время             = ВремяОтвета;
        Стр.ТекущаяОценкаТета = Окр(ТетаИтог * (1 - Exp(-Шаг / 3.0)), 2);
        Стр.ТекущаяSE         = Окр(Макс(SEИтог, 1.0 / Sqrt(Шаг)), 2);
    КонецЦикла;

    Сессия.ДатаОкончания     = ТекущееВремя;
    Сессия.ИтоговаяОценкаТета = Окр(ТетаИтог, 2);
    Сессия.ИтоговаяSE         = SEИтог;
    Сессия.ЧислоЗаданий       = Число;
    Сессия.СтатусСессии       = "Завершена";
    Сессия.Записать(РежимЗаписиДокумента.Проведение);

    Возврат Новый Структура("Ссылка, Верных, Всего", Сессия.Ссылка, Верных, Число);

КонецФункции

Процедура НаписатьОценку(Знач Студент, Знач Тема, Знач Тета, Знач SE, Знач Дата, Знач Источник)

    Менеджер = РегистрыСведений.ОценкиПодготовленностиПоТемам.СоздатьМенеджерЗаписи();
    Менеджер.Период      = Дата;
    Менеджер.Пользователь = Студент;
    Менеджер.Тема        = Тема;
    Менеджер.Тета        = Окр(Тета, 2);
    Менеджер.SE          = Окр(SE, 2);
    Если Источник <> Неопределено Тогда
        Менеджер.Источник = Источник;
    КонецЕсли;
    Менеджер.Записать(Истина);

КонецПроцедуры

Процедура НаписатьСобытие(Знач Студент, Знач Тема, Знач ТипСобытия, Знач Дата)

    Набор = РегистрыСведений.СобытияАналитики.СоздатьНаборЗаписей();
    Запись = Набор.Добавить();
    Запись.Период          = Дата;
    Запись.Пользователь    = Студент;
    Запись.Тема            = Тема;
    Запись.ТипСобытия      = ТипСобытия;
    Запись.КлючСобытия     = Строка(Новый УникальныйИдентификатор());
    Запись.ПолезнаяНагрузка = "{}";
    Набор.Записать(Ложь);

КонецПроцедуры

Процедура НаписатьНачисление(Знач Студент, Знач Тема, Знач Причина, Знач Количество, Знач Дата)

    Документ = Документы.НачислениеБаллов.СоздатьДокумент();
    Документ.Дата        = Дата;
    Документ.Обучающийся = Студент;
    Документ.Тема        = Тема;
    Документ.Причина     = Причина;
    Документ.Количество  = Количество;
    Документ.Записать(РежимЗаписиДокумента.Проведение);

КонецПроцедуры

Процедура НаписатьРейтингНаДату(Знач Группа, Знач Дата)

    Период = НачалоДня(Дата);
    Запрос = Новый Запрос(
        "ВЫБРАТЬ
        |   Состав.Пользователь                  КАК Пользователь,
        |   ЕСТЬNULL(Баллы.КоличествоОборот, 0)  КАК Сумма
        |ИЗ
        |   Справочник.УчебныеГруппы.Состав КАК Состав
        |   ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.БаллыОпыта.Обороты(, &Конец, , ) КАК Баллы
        |       ПО Баллы.Пользователь = Состав.Пользователь
        |ГДЕ Состав.Ссылка = &Группа
        |УПОРЯДОЧИТЬ ПО Сумма УБЫВ");
    Запрос.УстановитьПараметр("Группа", Группа);
    Запрос.УстановитьПараметр("Конец",  КонецДня(Дата));
    Выборка = Запрос.Выполнить().Выбрать();

    Набор = РегистрыСведений.РейтинговыеПозиции.СоздатьНаборЗаписей();
    Набор.Отбор.УчебнаяГруппа.Установить(Группа);
    Набор.Отбор.Период.Установить(Период);
    Ранг = 0;
    Пока Выборка.Следующий() Цикл
        Ранг = Ранг + 1;
        Запись = Набор.Добавить();
        Запись.Период        = Период;
        Запись.УчебнаяГруппа = Группа;
        Запись.Пользователь  = Выборка.Пользователь;
        Запись.СуммаБаллов   = Выборка.Сумма;
        Запись.Ранг          = Ранг;
        Запись.СредняяТета   = 0;
    КонецЦикла;
    Набор.Записать(Истина);

КонецПроцедуры

