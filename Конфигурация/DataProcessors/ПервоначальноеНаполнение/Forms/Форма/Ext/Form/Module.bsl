#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ВыполнитьНаполнениеВыполнить(Команда)

	Результат = ВыполнитьНаполнениеНаСервере(КаталогФикстур);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Запускает наполнение справочников эталонными данными и формирует текст результата.
//
// Параметры:
//  Каталог - Строка - путь к каталогу fixtures (пусто — путь по умолчанию).
//
// Возвращаемое значение:
//  Строка - сводка по наполнению или текст ошибки.
//
&НаСервереБезКонтекста
Функция ВыполнитьНаполнениеНаСервере(Знач Каталог)

	ИтогНаполнения = Обработки.ПервоначальноеНаполнение.Создать().ВыполнитьНаполнение(Каталог);

	Текст = СтрШаблон(
		НСтр("ru = 'Курсы: %1, темы: %2, задания: %3, бейджи: %4, материалы: %5'"),
		ИтогНаполнения.Курсы, 
		ИтогНаполнения.Темы, 
		ИтогНаполнения.Задания,
		ИтогНаполнения.Бейджи, 
		ИтогНаполнения.Материалы);

	Если ЗначениеЗаполнено(ИтогНаполнения.Ошибка) Тогда
		
		Текст = Текст + Символы.ПС + НСтр("ru = 'Ошибка: '") + ИтогНаполнения.Ошибка;
	КонецЕсли;

	Возврат Текст;

КонецФункции

#КонецОбласти
