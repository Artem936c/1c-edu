#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	Пользователь = ОбслуживаниеПользователейВызовСервера.ТекущийПользователь();

	// Подобрать первый активный курс пользователя (упрощённая логика)
	Запрос = Новый Запрос(
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|   Курсы.Ссылка КАК Ссылка
		|ИЗ
		|   Справочник.Курсы КАК Курсы
		|ГДЕ
		|   НЕ Курсы.ПометкаУдаления");
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	Если Выборка.Следующий() Тогда
		
		ТекущийКурс = Выборка.Ссылка;
		РекомендуемаяТема = ТраекторияОбучения.РекомендоватьСледующуюТему(Пользователь, ТекущийКурс);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура НачатьСессиюВыполнить(Команда)

	Если Не ЗначениеЗаполнено(РекомендуемаяТема) Тогда
		
		ПоказатьСообщениеПользователю(НСтр("ru = 'Нет рекомендуемой темы.'"));
		Возврат;
	КонецЕсли;

	ПараметрыФормы = Новый Структура;
	// Передаём тему через стандартный механизм ЗначенияЗаполнения, чтобы платформа
	// заполнила реквизит Объект.Тема ДО ПриСозданииНаСервере — там стартует сессия.
	ПараметрыФормы.Вставить("ЗначенияЗаполнения", Новый Структура("Тема", РекомендуемаяТема));
	// Заполнение Обучающийся произведём в форме документа на сервере
	ОткрытьФорму("Документ.ПопыткаТеста.ФормаОбъекта", ПараметрыФормы);

КонецПроцедуры

&НаКлиенте
Процедура ОткрытьДашбордВыполнить(Команда)

	ОткрытьФорму("Отчет.ДашбордОбучающегося.Форма.ФормаОтчёта");

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПоказатьСообщениеПользователю(Знач Текст)

	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = Текст;
	Сообщение.Сообщить();

КонецПроцедуры

#КонецОбласти
