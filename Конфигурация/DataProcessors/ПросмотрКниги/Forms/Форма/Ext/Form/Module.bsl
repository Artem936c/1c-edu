#Область ОбработчикиСобытийФормы

// Готовит форму просмотра книги по параметру МатериалИД (строковый GUID): определяет
// число предрендеренных страниц и показывает первую. Заголовок окна = наименование
// материала. Если страниц нет - показывается заглушка "Книга недоступна".
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	ИДМатериала = "";
	Параметры.Свойство("МатериалИД", ИДМатериала);

	ИмяКниги = "Книга недоступна";
	ТекущаяСтраница = 0;
	ВсегоСтраниц = 0;

	Если ЗначениеЗаполнено(ИДМатериала) Тогда
		МатериалСсылка = Справочники.МатериалыБиблиотеки.ПолучитьСсылку(
			Новый УникальныйИдентификатор(ИДМатериала));
		Заголовок = СокрЛП(МатериалСсылка.Наименование);

		ИмяФайла = МатериалСсылка.ИмяФайлаКниги;
		ИмяКниги = ?(ЗначениеЗаполнено(ИмяФайла), ИмяФайла, СокрЛП(МатериалСсылка.Наименование));

		ВсегоСтраниц = ЧислоСтраниц(МатериалСсылка);
		ТекущаяСтраница = ?(ВсегоСтраниц > 0, 1, 0);
	КонецЕсли;

	ПоказатьСтраницу();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

// Листание: якорные ссылки data-act=пред/след внутри HTML. Гасим штатную навигацию
// поля и пересобираем HTML под новую страницу на сервере.
&НаКлиенте
Процедура ПолеHTMLПриНажатии(Элемент, ДанныеСобытия, СтандартнаяОбработка)

	Якорь = ДанныеСобытия.Anchor;

	Если Якорь = Неопределено Тогда
		Возврат;
	КонецЕсли;

	СтандартнаяОбработка = Ложь;

	Действие = Якорь.getAttribute("data-act");

	Если Действие = "след" Тогда
		ПерейтиНаСтраницу(1);
	ИначеЕсли Действие = "пред" Тогда
		ПерейтиНаСтраницу(-1);
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Смещает текущую страницу на Дельта (в пределах книги) и перерисовывает.
&НаКлиенте
Процедура ПерейтиНаСтраницу(Знач Дельта)

	Новая = ТекущаяСтраница + Дельта;

	Если Новая >= 1 И Новая <= ВсегоСтраниц Тогда
		ТекущаяСтраница = Новая;
		ПоказатьСтраницу();
	КонецЕсли;

КонецПроцедуры

// Пересобирает ТекстHTML под текущую страницу: читает её PNG из реквизита
// СтраницыКниги, кодирует в base64 и подставляет в макет.
&НаСервере
Процедура ПоказатьСтраницу()

	СтраницаBase64 = "";

	Если ЗначениеЗаполнено(МатериалСсылка) И ВсегоСтраниц > 0 Тогда
		Страницы = МатериалСсылка.СтраницыКниги.Получить();
		Если ТипЗнч(Страницы) = Тип("Массив")
			И ТекущаяСтраница >= 1 И ТекущаяСтраница <= Страницы.Количество() Тогда

			Данные = Страницы[ТекущаяСтраница - 1];
			Если ТипЗнч(Данные) = Тип("ДвоичныеДанные") Тогда
				// Убираем переносы строк из base64 - чтобы корректно лёг в data:URI.
				Б64 = Base64Строка(Данные);
				Б64 = СтрЗаменить(Б64, Символы.ВК, "");
				СтраницаBase64 = СтрЗаменить(Б64, Символы.ПС, "");
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;

	ТекстHTML = Обработки.ПросмотрКниги.ПолучитьМакетКакСтроку(
		ИмяКниги, ТекущаяСтраница, ВсегоСтраниц, СтраницаBase64);

КонецПроцедуры

// Возвращает число предрендеренных страниц материала (0, если их нет).
&НаСервереБезКонтекста
Функция ЧислоСтраниц(Знач Материал)

	Хранилище = Материал.СтраницыКниги;
	Если Хранилище = Неопределено Тогда
		Возврат 0;
	КонецЕсли;

	Страницы = Хранилище.Получить();
	Возврат ?(ТипЗнч(Страницы) = Тип("Массив"), Страницы.Количество(), 0);

КонецФункции

#КонецОбласти
