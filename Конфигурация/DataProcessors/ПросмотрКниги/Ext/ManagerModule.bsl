#Область ПрограммныйИнтерфейс

// Формирует HTML-страницу просмотрщика книги: подставляет картинку текущей страницы
// (PNG в base64), имя книги и номер страницы в макет HTMLШаблонКниги. Пустой base64
// (книги/страниц нет) -> страница показывает заглушку с именем книги.
//
// Параметры:
//  ИмяКниги       - Строка - имя книги (заголовок панели; текст заглушки).
//  Номер          - Число  - номер текущей страницы (с 1).
//  Всего          - Число  - всего страниц.
//  СтраницаBase64 - Строка - PNG текущей страницы в base64 (может быть пустым).
//
// Возвращаемое значение:
//  Строка - HTML-текст просмотрщика.
//
Функция ПолучитьМакетКакСтроку(Знач ИмяКниги, Знач Номер, Знач Всего, Знач СтраницаBase64) Экспорт

	Текст = Обработки.ПросмотрКниги.ПолучитьМакет("HTMLШаблонКниги").ПолучитьТекст();

	Если ЗначениеЗаполнено(СтраницаBase64) Тогда
		Содержимое = "<img src=""data:image/png;base64," + СтраницаBase64 + """ alt=""Страница"">";
	Иначе
		Содержимое = "<div class=""msg"">" + ИмяКниги + "</div>";
	КонецЕсли;

	Текст = СтрЗаменить(Текст, "{{СОДЕРЖИМОЕ}}",  Содержимое);
	Текст = СтрЗаменить(Текст, "{{ИМЯ_КНИГИ}}",   ИмяКниги);
	Текст = СтрЗаменить(Текст, "{{НОМЕР}}",       Формат(Номер, "ЧГ=0; ЧН=0"));
	Текст = СтрЗаменить(Текст, "{{ВСЕГО}}",       Формат(Всего, "ЧГ=0; ЧН=0"));
	Текст = СтрЗаменить(Текст, "{{КЛАСС_ПРЕД}}", ?(Номер <= 1,     "disabled", ""));
	Текст = СтрЗаменить(Текст, "{{КЛАСС_СЛЕД}}", ?(Номер >= Всего, "disabled", ""));

	Возврат Текст;

КонецФункции

#КонецОбласти

#КонецЕсли
